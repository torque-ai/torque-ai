# TORQUE Configuration
# Copy to .env and fill in your values

# Cloud provider API keys (all optional - local Ollama works without these)
# DEEPINFRA_API_KEY=
# HYPERBOLIC_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=

# Ollama host (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Server ports (defaults shown)
# TORQUE_DASHBOARD_PORT=3456
# TORQUE_API_PORT=3457
# TORQUE_MCP_PORT=3458

# API authentication key (generate a random string)
# TORQUE_API_KEY=

# Telemetry (opt-in, default off)
# TORQUE_TELEMETRY=false
