#!/usr/bin/env node
'use strict';
const http = require('http');

const HOST = process.env.TORQUE_COORD_HOST || '127.0.0.1';
const PORT = parseInt(process.env.TORQUE_COORD_PORT || '9395', 10);
const CONNECT_TIMEOUT_MS = 2000;

const REMOTE_HOST = process.env.TORQUE_COORD_REMOTE_HOST || '';
const REMOTE_USER = process.env.TORQUE_COORD_REMOTE_USER || '';
const SSH_MODE = !!(REMOTE_HOST && REMOTE_USER);
const SSH_TIMEOUT_SECS = parseInt(process.env.TORQUE_COORD_SSH_TIMEOUT || '5', 10);
// Allow tests to inject a fake ssh binary without relying on PATH or PATHEXT.
// Supports two forms:
//   TORQUE_COORD_SSH_BIN=ssh          (default — use system ssh)
//   TORQUE_COORD_SSH_BIN=node:/path   (test mode — spawns node <path> <args>)
// The "node:" prefix lets tests on Windows bypass the PATHEXT/.cmd/.shell issues
// entirely: the coord-client spawns node.exe directly with the script path.
const SSH_BIN_RAW = process.env.TORQUE_COORD_SSH_BIN || 'ssh';
const SSH_BIN_IS_NODE = SSH_BIN_RAW.startsWith('node:');
const SSH_BIN = SSH_BIN_IS_NODE ? process.execPath : SSH_BIN_RAW;
const SSH_SCRIPT = SSH_BIN_IS_NODE ? SSH_BIN_RAW.slice(5) : null;

function emit(obj) {
  process.stdout.write(JSON.stringify(obj) + '\n');
}

function unreachable(detail) {
  emit({ status: 'unreachable', detail });
  process.exit(2);
}

function parseArgs(argv) {
  const out = {};
  for (let i = 0; i < argv.length; i += 2) {
    const key = argv[i];
    const value = argv[i + 1];
    if (!key || !key.startsWith('--')) {
      throw new Error(`unexpected positional argument: ${key}`);
    }
    if (value === undefined || value.startsWith('--')) {
      throw new Error(`flag ${key} missing a value`);
    }
    out[key.slice(2)] = value;
  }
  return out;
}

function request({ method, path, body }) {
  return new Promise((resolve, reject) => {
    const opts = {
      hostname: HOST, port: PORT, path, method,
      headers: { 'content-type': 'application/json' },
      timeout: CONNECT_TIMEOUT_MS,
    };
    const req = http.request(opts, (res) => {
      const chunks = [];
      res.on('data', (c) => chunks.push(c));
      res.on('end', () => {
        const text = Buffer.concat(chunks).toString('utf8');
        let json = null;
        try { json = text ? JSON.parse(text) : null; } catch (_e) { /* not json */ }
        resolve({ status: res.statusCode, body: json });
      });
    });
    req.on('error', reject);
    req.on('timeout', () => req.destroy(new Error('timeout')));
    // The `timeout` option on http.request is an INACTIVITY timeout — it only
    // fires once a socket exists. When the OS firewall silently drops SYNs to a
    // closed port (Windows Defender against port 1, for example), the connect
    // itself blocks for the full OS TCP connect timeout (~20s) before
    // surfacing ECONNREFUSED, which is longer than callers expect. Bind the
    // socket-level timeout the moment the socket exists so connect-stage
    // hangs surface in CONNECT_TIMEOUT_MS regardless of OS connect behavior.
    req.on('socket', (socket) => {
      socket.setTimeout(CONNECT_TIMEOUT_MS);
      socket.once('timeout', () => req.destroy(new Error('connect timeout')));
    });
    if (body) req.write(JSON.stringify(body));
    req.end();
  });
}

// Escape a string for use inside a cmd.exe double-quoted argument.
// The remote workstation's sshd runs the command through cmd.exe.
// Inside cmd.exe double-quoted strings, only `"` needs escaping.
function cmdQuote(s) {
  return '"' + s.replace(/"/g, '\\"') + '"';
}

function requestViaSsh({ method, path: urlPath, body }) {
  return new Promise((resolve, reject) => {
    const { spawn } = require('child_process');
    // Build a curl invocation that runs on the remote workstation.
    // -s silent; -w appends a sentinel + HTTP status code so we can
    // separate it from the response body without relying on newlines.
    // The sentinel is a plain alphanumeric string that cannot appear in
    // valid JSON, so indexOf is a safe split point.
    //
    // We pass the entire curl command as a SINGLE argument to ssh (after
    // the hostname). This is key: ssh sends a single-string command to
    // the remote shell (cmd.exe), which then parses it normally.
    // Passing individual args causes ssh to join them with spaces and
    // Windows CreateProcess quoting can mangle %{...} in the -w format.
    // A single pre-built cmd.exe-safe string avoids that entirely.
    const SENTINEL = 'HTTPSTATUS:';
    const url = `http://127.0.0.1:9395${urlPath}`;
    const curlParts = [
      'curl', '-s',
      '--max-time', String(SSH_TIMEOUT_SECS),
      '-X', method,
      '-H', cmdQuote('content-type: application/json'),
      '-w', `HTTPSTATUS:%{http_code}`,
    ];
    if (body) {
      // pass body via stdin
      curlParts.push('--data-binary', '@-');
    }
    curlParts.push(url);
    const remoteCmd = curlParts.join(' ');
    const sshArgs = [
      '-o', `ConnectTimeout=${SSH_TIMEOUT_SECS}`,
      '-o', 'StrictHostKeyChecking=accept-new',
      `${REMOTE_USER}@${REMOTE_HOST}`,
      remoteCmd,
    ];
    const spawnArgs = SSH_SCRIPT ? [SSH_SCRIPT, ...sshArgs] : sshArgs;
    // .cmd files on Windows require shell:true for CreateProcess to execute them.
    const useShell = SSH_BIN.toLowerCase().endsWith('.cmd');
    const proc = spawn(SSH_BIN, spawnArgs, { windowsHide: true, shell: useShell });
    let stdout = '';
    let stderr = '';
    proc.stdout.on('data', (chunk) => { stdout += chunk.toString('utf8'); });
    proc.stderr.on('data', (chunk) => { stderr += chunk.toString('utf8'); });
    proc.on('error', reject);
    proc.on('close', (code) => {
      if (code !== 0) {
        return reject(new Error(`ssh exited ${code}: ${stderr.trim().slice(0, 200) || 'no stderr'}`));
      }
      // Split on sentinel to extract body + status code.
      const idx = stdout.indexOf(SENTINEL);
      const text = idx >= 0 ? stdout.slice(0, idx) : stdout;
      const statusStr = idx >= 0 ? stdout.slice(idx + SENTINEL.length).trim() : '';
      const httpCode = parseInt(statusStr, 10);
      let json = null;
      try { json = text ? JSON.parse(text) : null; } catch (_e) { /* not json */ }
      resolve({ status: Number.isFinite(httpCode) ? httpCode : 0, body: json });
    });
    if (body) {
      proc.stdin.end(JSON.stringify(body));
    } else {
      proc.stdin.end();
    }
  });
}

function streamViaSsh({ path: urlPath, onFrame }) {
  return new Promise((resolve, reject) => {
    const { spawn } = require('child_process');
    const url = `http://127.0.0.1:9395${urlPath}`;
    // Same single-command-string approach as requestViaSsh.
    const curlParts2 = [
      'curl', '-s', '-N',  // -N: no buffering, keep SSE frames flowing
      '-H', cmdQuote('accept: text/event-stream'),
      url,
    ];
    const remoteCmd2 = curlParts2.join(' ');
    const sshArgs = [
      '-o', `ConnectTimeout=${SSH_TIMEOUT_SECS}`,
      '-o', 'StrictHostKeyChecking=accept-new',
      `${REMOTE_USER}@${REMOTE_HOST}`,
      remoteCmd2,
    ];
    const spawnArgs2 = SSH_SCRIPT ? [SSH_SCRIPT, ...sshArgs] : sshArgs;
    const useShell2 = SSH_BIN.toLowerCase().endsWith('.cmd');
    const proc = spawn(SSH_BIN, spawnArgs2, { windowsHide: true, shell: useShell2 });
    let buf = '';
    proc.stdout.setEncoding('utf8');
    proc.stdout.on('data', (chunk) => {
      buf += chunk;
      let idx;
      while ((idx = buf.indexOf('\n\n')) >= 0) {
        const frame = buf.slice(0, idx);
        buf = buf.slice(idx + 2);
        const dataLine = frame.split('\n').find((l) => l.startsWith('data: '));
        if (dataLine) {
          try {
            const parsed = JSON.parse(dataLine.slice(6));
            const stop = onFrame(parsed);
            if (stop) {
              proc.kill('SIGTERM');
              return resolve();
            }
          } catch (_e) { /* malformed frame, ignore */ }
        }
      }
    });
    proc.on('error', reject);
    proc.on('close', () => resolve());
  });
}

function dispatch(args) {
  return SSH_MODE ? requestViaSsh(args) : request(args);
}

// Single-process replacement for the bash-driven sequence
// `lock-hashes` -> `results` -> `acquire`. Returns one of the begin event
// objects: cache_hit / acquired / queued / error. Throws on transport
// failure; the case 'begin' caller catches and emits the unreachable event.
// HTTP calls go through dispatch() so this works in both local and ssh modes
// (Phase 3c). The lock-hashes computation always runs locally — it hashes
// the dev box's working tree, which is what the cache key is built against.
async function runBegin(args) {
  const root = args.root || process.cwd();
  const { computeLockHashes } = require('../server/coord/lock-hashes');
  const localHashes = computeLockHashes(root);
  const localHashesJson = JSON.stringify(localHashes);

  // Cache-hit path.
  const resultsPath = `/results/${encodeURIComponent(args.project)}/${encodeURIComponent(args.sha)}/${encodeURIComponent(args.suite)}`;
  const resultsResp = await dispatch({ method: 'GET', path: resultsPath });
  if (resultsResp.status === 200 && resultsResp.body && resultsResp.body.hit !== false) {
    const stored = (resultsResp.body && resultsResp.body.package_lock_hashes) || {};
    let allMatch = true;
    for (const k of Object.keys(stored)) {
      if (localHashes[k] !== stored[k]) { allMatch = false; break; }
    }
    if (allMatch) {
      return {
        event: 'cache_hit',
        exit_code: resultsResp.body.exit_code != null ? resultsResp.body.exit_code : 1,
        output_tail: resultsResp.body.output_tail || '',
      };
    }
    // Hash mismatch — surface to stderr (integration tests assert on this
    // line and operators want to see why the cached result got discarded)
    // and fall through to acquire.
    process.stderr.write('[torque-coord] hash mismatch on cached result, running fresh\n');
  }
  // Server errors on results (non-200/non-404) fall through to acquire —
  // acquire is the real gate; if the server is healthy enough to answer
  // /acquire we proceed, otherwise the caller surfaces the error event.

  const acquireBody = {
    project: args.project,
    sha: args.sha,
    suite: args.suite,
    holder: {
      host: args.host || require('os').hostname(),
      pid: parseInt(args.pid || String(process.pid), 10),
      user: args.user || (process.env.USER || process.env.USERNAME || 'unknown'),
    },
  };
  const acqResp = await dispatch({ method: 'POST', path: '/acquire', body: acquireBody });
  if (acqResp.status === 200 && acqResp.body && acqResp.body.lock_id) {
    return { event: 'acquired', lock_id: acqResp.body.lock_id, local_hashes: localHashesJson };
  }
  if (acqResp.status === 202 && acqResp.body && acqResp.body.wait_for) {
    return { event: 'queued', wait_for: acqResp.body.wait_for, local_hashes: localHashesJson };
  }
  return { event: 'error', status: acqResp.status, body: acqResp.body };
}

async function main() {
  const [, , subcommand, ...rest] = process.argv;
  let args;
  try {
    args = parseArgs(rest);
  } catch (err) {
    emit({ status: 'usage_error', detail: err.message });
    process.exit(64);
  }

  try {
    switch (subcommand) {
      case 'health': {
        const r = await dispatch({ method: 'GET', path: '/health' });
        emit(r.body);
        process.exit(r.status === 200 ? 0 : 1);
        break;
      }
      case 'acquire': {
        const body = {
          project: args.project,
          sha: args.sha,
          suite: args.suite,
          holder: {
            host: args.host || require('os').hostname(),
            pid: parseInt(args.pid || String(process.pid), 10),
            user: args.user || (process.env.USER || process.env.USERNAME || 'unknown'),
          },
        };
        const r = await dispatch({ method: 'POST', path: '/acquire', body });
        emit(r.body);
        process.exit(r.status === 200 ? 0 : (r.status === 202 ? 3 : 1));
        break;
      }
      case 'heartbeat': {
        const body = { lock_id: args['lock-id'], log_chunk: args.log || '' };
        const r = await dispatch({ method: 'POST', path: '/heartbeat', body });
        emit(r.body);
        process.exit(r.status === 200 ? 0 : 1);
        break;
      }
      case 'release': {
        let parsedHashes = {};
        if (args.hashes) {
          try { parsedHashes = JSON.parse(args.hashes); }
          catch (_e) { parsedHashes = {}; }
        }
        // Tail content is normally captured by the wrapper into a tempfile
        // and passed via --tail-from-file. Reading from a file lets us
        // bypass shell-quoting limits on arbitrary inner-command output
        // (newlines, quotes, ANSI, etc.). --tail still works for tiny
        // synthetic values in tests.
        let tailContent = args.tail || '';
        if (args['tail-from-file']) {
          try {
            const fs = require('fs');
            const buf = fs.readFileSync(args['tail-from-file']);
            const sliced = buf.length > 16384 ? buf.slice(buf.length - 16384) : buf;
            tailContent = sliced.toString('utf8');
          } catch (_e) {
            tailContent = '';
          }
        }
        const body = {
          lock_id: args['lock-id'],
          exit_code: parseInt(args.exit || '0', 10),
          suite_status: args.status || 'unknown',
          output_tail: tailContent,
          package_lock_hashes: parsedHashes,
        };
        const r = await dispatch({ method: 'POST', path: '/release', body });
        emit(r.body);
        process.exit(r.status === 200 ? 0 : 1);
        break;
      }
      case 'results': {
        const r = await dispatch({
          method: 'GET',
          path: `/results/${encodeURIComponent(args.project)}/${encodeURIComponent(args.sha)}/${encodeURIComponent(args.suite)}`,
        });
        if (r.status === 404) { emit({ hit: false }); process.exit(0); }
        emit(r.body);
        process.exit(r.status === 200 ? 0 : 1);
        break;
      }
      case 'wait': {
        if (SSH_MODE) {
          await streamViaSsh({
            path: `/wait/${encodeURIComponent(args['lock-id'])}`,
            onFrame: (parsed) => {
              emit(parsed);
              return parsed.type === 'released' || parsed.type === 'holder_crashed';
            },
          });
          process.exit(0);
        }
        // No request.timeout for wait — it's an inactivity timeout that
        // would kill long streams. The daemon emits progress every 5s but
        // a quiet stretch is normal. Daemon-down is detected by the socket
        // error handler below; that's sufficient.
        const opts = {
          hostname: HOST, port: PORT,
          path: `/wait/${encodeURIComponent(args['lock-id'])}`,
          method: 'GET',
          headers: { accept: 'text/event-stream' },
        };
        await new Promise((resolve, reject) => {
          const req = http.request(opts, (res) => {
            res.setEncoding('utf8');
            let buf = '';
            res.on('data', (chunk) => {
              buf += chunk;
              let idx;
              while ((idx = buf.indexOf('\n\n')) >= 0) {
                const frame = buf.slice(0, idx);
                buf = buf.slice(idx + 2);
                const dataLine = frame.split('\n').find((l) => l.startsWith('data: '));
                if (dataLine) {
                  const parsed = JSON.parse(dataLine.slice(6));
                  emit(parsed);
                  if (parsed.type === 'released' || parsed.type === 'holder_crashed') {
                    res.destroy();
                    resolve();
                  }
                }
              }
            });
            res.on('error', reject);
            res.on('end', resolve);
          });
          req.on('error', reject);
          req.end();
        });
        process.exit(0);
        break;
      }
      case 'lock-hashes': {
        const root = args.root || process.cwd();
        const { computeLockHashes } = require('../server/coord/lock-hashes');
        emit(computeLockHashes(root));
        process.exit(0);
        break;
      }
      case 'begin': {
        // Single-process replacement for the prior bash-driven sequence
        // `lock-hashes` -> `results` -> `acquire`. Each separate node spawn
        // costs ~9s of cold-start time on the Windows test remote (Defender
        // real-time scan), so the bash-driven flow paid 27-36s of pure
        // startup before the user command ran. This subcommand collapses
        // that to a single 9s startup regardless of which path runs.
        //
        // Output (single JSON line) — bash parses by extracting "event":
        //   {"event":"cache_hit","exit_code":N,"output_tail":"..."}
        //     → bash prints output_tail and exits with exit_code
        //   {"event":"acquired","lock_id":"...","local_hashes":"<json>"}
        //     → bash sets COORD_ACQUIRED=1 + runs the user command
        //   {"event":"queued","wait_for":"...","local_hashes":"<json>"}
        //     → bash runs `wait`, then re-runs `begin`
        //   {"event":"unreachable"}
        //     → bash proceeds uncoordinated (matches prior exit-2 behavior)
        //
        // Exit codes (mirroring the per-call codes so callers can still
        // branch on rc instead of parsing JSON when they don't need detail):
        //   0  acquired or cache_hit
        //   1  protocol/server error
        //   2  unreachable
        //   3  queued (caller must wait + re-call begin)
        try {
          const ev = await runBegin(args);
          emit(ev);
          if (ev.event === 'cache_hit' || ev.event === 'acquired') process.exit(0);
          if (ev.event === 'queued') process.exit(3);
          if (ev.event === 'unreachable') process.exit(2);
          process.exit(1);
        } catch (err) {
          // Connect failures and other transport errors land here. Emit the
          // event-shaped output that bash's coord_begin expects (rather than
          // the legacy {"status":"unreachable",...} from the shared
          // unreachable() helper, which doesn't have an "event" field for
          // bash's sed-based extractor and was causing the unreachable test
          // to fail with the wrong stderr message).
          emit({ event: 'unreachable', detail: err.message });
          process.exit(2);
        }
        break;
      }
      default:
        emit({ status: 'usage_error', detail: `unknown subcommand: ${subcommand || '(none)'}` });
        process.exit(64);
    }
  } catch (err) {
    unreachable(err.message);
  }
}

main();
