#!/usr/bin/env node
'use strict';
const http = require('http');

const HOST = process.env.TORQUE_COORD_HOST || '127.0.0.1';
const PORT = parseInt(process.env.TORQUE_COORD_PORT || '9395', 10);
const CONNECT_TIMEOUT_MS = 2000;

function emit(obj) {
  process.stdout.write(JSON.stringify(obj) + '\n');
}

function unreachable(detail) {
  emit({ status: 'unreachable', detail });
  process.exit(2);
}

function parseArgs(argv) {
  const out = {};
  for (let i = 0; i < argv.length; i += 2) {
    const key = argv[i];
    const value = argv[i + 1];
    if (!key || !key.startsWith('--')) {
      throw new Error(`unexpected positional argument: ${key}`);
    }
    if (value === undefined || value.startsWith('--')) {
      throw new Error(`flag ${key} missing a value`);
    }
    out[key.slice(2)] = value;
  }
  return out;
}

function request({ method, path, body }) {
  return new Promise((resolve, reject) => {
    const opts = {
      hostname: HOST, port: PORT, path, method,
      headers: { 'content-type': 'application/json' },
      timeout: CONNECT_TIMEOUT_MS,
    };
    const req = http.request(opts, (res) => {
      const chunks = [];
      res.on('data', (c) => chunks.push(c));
      res.on('end', () => {
        const text = Buffer.concat(chunks).toString('utf8');
        let json = null;
        try { json = text ? JSON.parse(text) : null; } catch (_e) { /* not json */ }
        resolve({ status: res.statusCode, body: json });
      });
    });
    req.on('error', reject);
    req.on('timeout', () => req.destroy(new Error('timeout')));
    // The `timeout` option on http.request is an INACTIVITY timeout — it only
    // fires once a socket exists. When the OS firewall silently drops SYNs to a
    // closed port (Windows Defender against port 1, for example), the connect
    // itself blocks for the full OS TCP connect timeout (~20s) before
    // surfacing ECONNREFUSED, which is longer than callers expect. Bind the
    // socket-level timeout the moment the socket exists so connect-stage
    // hangs surface in CONNECT_TIMEOUT_MS regardless of OS connect behavior.
    req.on('socket', (socket) => {
      socket.setTimeout(CONNECT_TIMEOUT_MS);
      socket.once('timeout', () => req.destroy(new Error('connect timeout')));
    });
    if (body) req.write(JSON.stringify(body));
    req.end();
  });
}

async function main() {
  const [, , subcommand, ...rest] = process.argv;
  let args;
  try {
    args = parseArgs(rest);
  } catch (err) {
    emit({ status: 'usage_error', detail: err.message });
    process.exit(64);
  }

  try {
    switch (subcommand) {
      case 'health': {
        const r = await request({ method: 'GET', path: '/health' });
        emit(r.body);
        process.exit(r.status === 200 ? 0 : 1);
        break;
      }
      case 'acquire': {
        const body = {
          project: args.project,
          sha: args.sha,
          suite: args.suite,
          holder: {
            host: args.host || require('os').hostname(),
            pid: parseInt(args.pid || String(process.pid), 10),
            user: args.user || (process.env.USER || process.env.USERNAME || 'unknown'),
          },
        };
        const r = await request({ method: 'POST', path: '/acquire', body });
        emit(r.body);
        process.exit(r.status === 200 ? 0 : (r.status === 202 ? 3 : 1));
        break;
      }
      case 'heartbeat': {
        const body = { lock_id: args['lock-id'], log_chunk: args.log || '' };
        const r = await request({ method: 'POST', path: '/heartbeat', body });
        emit(r.body);
        process.exit(r.status === 200 ? 0 : 1);
        break;
      }
      case 'release': {
        let parsedHashes = {};
        if (args.hashes) {
          try { parsedHashes = JSON.parse(args.hashes); }
          catch (_e) { parsedHashes = {}; }
        }
        const body = {
          lock_id: args['lock-id'],
          exit_code: parseInt(args.exit || '0', 10),
          suite_status: args.status || 'unknown',
          output_tail: args.tail || '',
          package_lock_hashes: parsedHashes,
        };
        const r = await request({ method: 'POST', path: '/release', body });
        emit(r.body);
        process.exit(r.status === 200 ? 0 : 1);
        break;
      }
      case 'results': {
        const r = await request({
          method: 'GET',
          path: `/results/${encodeURIComponent(args.project)}/${encodeURIComponent(args.sha)}/${encodeURIComponent(args.suite)}`,
        });
        if (r.status === 404) { emit({ hit: false }); process.exit(0); }
        emit(r.body);
        process.exit(r.status === 200 ? 0 : 1);
        break;
      }
      case 'wait': {
        // No request.timeout for wait — it's an inactivity timeout that
        // would kill long streams. The daemon emits progress every 5s but
        // a quiet stretch is normal. Daemon-down is detected by the socket
        // error handler below; that's sufficient.
        const opts = {
          hostname: HOST, port: PORT,
          path: `/wait/${encodeURIComponent(args['lock-id'])}`,
          method: 'GET',
          headers: { accept: 'text/event-stream' },
        };
        await new Promise((resolve, reject) => {
          const req = http.request(opts, (res) => {
            res.setEncoding('utf8');
            let buf = '';
            res.on('data', (chunk) => {
              buf += chunk;
              let idx;
              while ((idx = buf.indexOf('\n\n')) >= 0) {
                const frame = buf.slice(0, idx);
                buf = buf.slice(idx + 2);
                const dataLine = frame.split('\n').find((l) => l.startsWith('data: '));
                if (dataLine) {
                  const parsed = JSON.parse(dataLine.slice(6));
                  emit(parsed);
                  if (parsed.type === 'released' || parsed.type === 'holder_crashed') {
                    res.destroy();
                    resolve();
                  }
                }
              }
            });
            res.on('error', reject);
            res.on('end', resolve);
          });
          req.on('error', reject);
          req.end();
        });
        process.exit(0);
        break;
      }
      case 'lock-hashes': {
        const root = args.root || process.cwd();
        const { computeLockHashes } = require('../server/coord/lock-hashes');
        emit(computeLockHashes(root));
        process.exit(0);
        break;
      }
      case 'begin': {
        // Single-process replacement for the prior bash-driven sequence
        // `lock-hashes` -> `results` -> `acquire`. Each separate node spawn
        // costs ~9s of cold-start time on the Windows test remote (Defender
        // real-time scan), so the bash-driven flow paid 27-36s of pure
        // startup before the user command ran. This subcommand collapses
        // that to a single 9s startup regardless of which path runs.
        //
        // Output (single JSON line) — bash parses by extracting "event":
        //   {"event":"cache_hit","exit_code":N,"output_tail":"..."}
        //     → bash prints output_tail and exits with exit_code
        //   {"event":"acquired","lock_id":"...","local_hashes":"<json>"}
        //     → bash sets COORD_ACQUIRED=1 + runs the user command
        //   {"event":"queued","wait_for":"...","local_hashes":"<json>"}
        //     → bash runs `wait`, then re-runs `begin`
        //   {"event":"unreachable"}
        //     → bash proceeds uncoordinated (matches prior exit-2 behavior)
        //
        // Exit codes (mirroring the per-call codes so callers can still
        // branch on rc instead of parsing JSON when they don't need detail):
        //   0  acquired or cache_hit
        //   1  protocol/server error
        //   2  unreachable
        //   3  queued (caller must wait + re-call begin)
        const root = args.root || process.cwd();
        const { computeLockHashes } = require('../server/coord/lock-hashes');
        const localHashes = computeLockHashes(root);
        const localHashesJson = JSON.stringify(localHashes);
        // Try the cache-hit path first.
        const resultsPath = `/results/${encodeURIComponent(args.project)}/${encodeURIComponent(args.sha)}/${encodeURIComponent(args.suite)}`;
        const resultsResp = await request({ method: 'GET', path: resultsPath });
        if (resultsResp.status === 200 && resultsResp.body && resultsResp.body.hit !== false) {
          const stored = (resultsResp.body && resultsResp.body.package_lock_hashes) || {};
          let allMatch = true;
          for (const k of Object.keys(stored)) {
            if (localHashes[k] !== stored[k]) { allMatch = false; break; }
          }
          if (allMatch) {
            emit({
              event: 'cache_hit',
              exit_code: resultsResp.body.exit_code != null ? resultsResp.body.exit_code : 1,
              output_tail: resultsResp.body.output_tail || '',
            });
            process.exit(0);
          }
          // hashes mismatch — fall through to acquire below
        } else if (resultsResp.status !== 200 && resultsResp.status !== 404) {
          // Server error on results — surface it but still try acquire
          // since acquire is the actual gate. (rc=1 if acquire also fails.)
        }
        // Acquire.
        const acquireBody = {
          project: args.project,
          sha: args.sha,
          suite: args.suite,
          holder: {
            host: args.host || require('os').hostname(),
            pid: parseInt(args.pid || String(process.pid), 10),
            user: args.user || (process.env.USER || process.env.USERNAME || 'unknown'),
          },
        };
        const acqResp = await request({ method: 'POST', path: '/acquire', body: acquireBody });
        if (acqResp.status === 200 && acqResp.body && acqResp.body.lock_id) {
          emit({ event: 'acquired', lock_id: acqResp.body.lock_id, local_hashes: localHashesJson });
          process.exit(0);
        }
        if (acqResp.status === 202 && acqResp.body && acqResp.body.wait_for) {
          emit({ event: 'queued', wait_for: acqResp.body.wait_for, local_hashes: localHashesJson });
          process.exit(3);
        }
        emit({ event: 'error', status: acqResp.status, body: acqResp.body });
        process.exit(1);
        break;
      }
      default:
        emit({ status: 'usage_error', detail: `unknown subcommand: ${subcommand || '(none)'}` });
        process.exit(64);
    }
  } catch (err) {
    unreachable(err.message);
  }
}

main();
