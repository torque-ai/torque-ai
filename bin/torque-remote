#!/usr/bin/env bash
set -euo pipefail

# SCRIPT_DIR is needed for locating torque-coord-client (sibling script).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# torque-remote — Route commands to the configured remote workstation.
# Usage: torque-remote <command...>
#   Routes the command to the remote workstation via SSH.
#   Falls back to local execution if remote is unreachable or overloaded.
#
# Config (highest priority wins):
#   .torque-remote.json in project root (per-project override)
#   ~/.torque-remote.json (global default)
#
# Connection details:
#   .torque-remote.local.json in project root (per-project)
#   ~/.torque-remote.local.json (global)

# ---- Helpers ----

die()  { echo "[torque-remote] ERROR: $*" >&2; exit 1; }
warn() { echo "[torque-remote] WARNING: $*" >&2; }
info() { echo "[torque-remote] $*" >&2; }

json_get_without_jq() {
  local file="$1" field="$2" key raw
  key="${field#.}"

  [[ -f "$file" ]] || return 0

  raw="$(
    tr -d '\r\n' < "$file" |
      sed -nE "s/.*\"$key\"[[:space:]]*:[[:space:]]*(\"([^\"\\\\]|\\\\.)*\"|true|false|null|-?[0-9]+([.][0-9]+)?).*/\1/p" |
      head -n 1
  )"

  if [[ -z "$raw" || "$raw" == "null" ]]; then
    return 0
  fi

  if [[ "$raw" == \"*\" ]]; then
    raw="${raw:1:${#raw}-2}"
    raw="${raw//\\\\/\\}"
    raw="${raw//\\\"/\"}"
  fi

  printf '%s\n' "$raw"
}

json_get() {
  local file="$1" field="$2"

  if command -v jq >/dev/null 2>&1; then
    jq -r "$field // empty" "$file" 2>/dev/null | tr -d '\r' || true
    return 0
  fi

  json_get_without_jq "$file" "$field"
}

TEMP_DIRS=()
REMOTE_CLEANUP_COMMAND=""
REMOTE_CLEANUP_REQUIRED="false"

cleanup_temp_dirs() {
  local dir attempt
  for dir in "${TEMP_DIRS[@]}"; do
    [[ -z "$dir" || ! -d "$dir" ]] && continue
    # Retry rm -rf up to 3x with backoff. On Windows, Defender (and other
    # AV/indexers) routinely hold open handles to large files like
    # local-state.tar (~4GB) and untracked.tar (~4GB) for a few seconds
    # after the bash process closes them. The first rm -rf often races
    # those handles and silently leaves the dir on disk — that's how this
    # script accumulated ~150GB of orphans before this hardening landed.
    for attempt in 1 2 3; do
      if rm -rf "$dir" 2>/dev/null; then
        break
      fi
      sleep 1
    done
    if [[ -d "$dir" ]]; then
      # Loud signal so a future operator can grep for these instead of
      # discovering the leak via "C: drive at 0% free."
      printf '[torque-remote] WARN: failed to remove temp dir %s — leaked, AV or indexer likely held handles\n' "$dir" >&2
    fi
  done
}

# Best-effort sweep of orphans from prior runs that this process did not
# create. Triggered once per invocation (after our own cleanup) so the
# disk-pressure failure mode self-heals over time even if a few cleanups
# leak. Anything older than 1 hour is fair game — fresh dirs may belong to
# a concurrent torque-remote invocation.
sweep_old_orphans() {
  local tmp_root="${TMPDIR:-/tmp}"
  [[ ! -d "$tmp_root" ]] && return 0
  find "$tmp_root" -maxdepth 1 -type d -name 'torque-remote.*' -mmin +60 \
    -exec rm -rf {} + 2>/dev/null || true
}

make_temp_dir() {
  local dir
  dir="$(mktemp -d "${TMPDIR:-/tmp}/torque-remote.XXXXXX")"
  TEMP_DIRS+=("$dir")
  printf '%s\n' "$dir"
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

format_command_for_log() {
  local part parts=()
  for part in "$@"; do
    parts+=("$(printf '%q' "$part")")
  done
  local joined=""
  if [[ ${#parts[@]} -gt 0 ]]; then
    joined="${parts[0]}"
    for part in "${parts[@]:1}"; do
      joined+=" $part"
    done
  fi
  printf '%s\n' "$joined"
}

bash_array_literal() {
  local name="$1"
  shift

  printf '%s=(\n' "$name"
  local item
  for item in "$@"; do
    printf '  %q\n' "$item"
  done
  printf ')\n'
}

run_with_timeout() {
  local timeout_seconds="$1"
  shift

  if [[ "$timeout_seconds" == "0" ]]; then
    "$@"
    return $?
  fi

  local timeout_marker watcher_pid command_pid exit_code stdin_fd
  timeout_marker="$(make_temp_dir)/timed_out"

  exec {stdin_fd}<&0
  "$@" <&"$stdin_fd" &
  command_pid=$!
  exec {stdin_fd}<&-

  (
    sleep "$timeout_seconds"
    if kill -0 "$command_pid" 2>/dev/null; then
      : > "$timeout_marker"
      kill -TERM "$command_pid" 2>/dev/null || true
      sleep 1
      kill -KILL "$command_pid" 2>/dev/null || true
    fi
  ) &
  watcher_pid=$!

  wait "$command_pid"
  exit_code=$?

  kill "$watcher_pid" 2>/dev/null || true
  wait "$watcher_pid" 2>/dev/null || true

  if [[ -f "$timeout_marker" ]]; then
    return 124
  fi

  return "$exit_code"
}

cleanup_remote_exec() {
  if [[ "$REMOTE_CLEANUP_REQUIRED" != "true" || -z "$REMOTE_CLEANUP_COMMAND" ]]; then
    return 0
  fi

  if ! ssh "${SSH_OPTS[@]}" "$SSH_USER@$SSH_HOST" "$REMOTE_CLEANUP_COMMAND" >/dev/null 2>&1; then
    warn "Best-effort remote cleanup failed for $SSH_USER@$SSH_HOST:$REMOTE_PROJECT_PATH"
  fi

  REMOTE_CLEANUP_REQUIRED="false"
  REMOTE_CLEANUP_COMMAND=""
}

cleanup_on_exit() {
  cleanup_remote_exec
  cleanup_temp_dirs
  sweep_old_orphans
}

resolve_sync_ref() {
  local branch="$1"

  if [[ -n "$branch" ]] && git rev-parse --verify "origin/$branch" >/dev/null 2>&1; then
    printf 'origin/%s\n' "$branch"
    return 0
  fi

  local candidate
  for candidate in origin/main origin/master; do
    if git rev-parse --verify "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

create_local_state_bundle() {
  # Build a tar bundle delivered to the remote over SSH stdin. Always includes
  # runner.sh (the body bash runs remotely) so the SSH command line can stay a
  # tiny cmd.exe-safe bootstrap instead of an escaped multi-line script.
  # Patches/untracked are added only when capture_local_state=true AND local
  # state differs from base_ref. Returns "<bundle_path>\n<has_local_state>\n".
  #
  # Args: $1 = base ref; $2 = runner.sh body; $3 = capture_local_state ("true"|"false").
  local base_ref="$1"
  local runner_body="$2"
  local capture_local_state="${3:-true}"
  local bundle_dir committed_patch worktree_patch untracked_list bundle_tar
  local has_local_state="false"

  bundle_dir="$(make_temp_dir)"
  committed_patch="$bundle_dir/committed.patch"
  worktree_patch="$bundle_dir/worktree.patch"
  untracked_list="$bundle_dir/untracked.list"
  bundle_tar="$bundle_dir/local-state.tar"

  if [[ "$capture_local_state" == "true" ]]; then
    git diff --binary "$base_ref..HEAD" > "$committed_patch"
    git diff --binary HEAD > "$worktree_patch"
    git ls-files --others --exclude-standard -z > "$untracked_list"

    if [[ -s "$committed_patch" || -s "$worktree_patch" || -s "$untracked_list" ]]; then
      has_local_state="true"
    fi

    if [[ -s "$untracked_list" ]]; then
      tar -cf "$bundle_dir/untracked.tar" --null -T "$untracked_list"
    fi
  fi

  printf '%s' "$runner_body" > "$bundle_dir/runner.sh"

  local tar_args=(runner.sh)
  [[ -s "$committed_patch" ]] && tar_args+=(committed.patch)
  [[ -s "$worktree_patch" ]]  && tar_args+=(worktree.patch)
  [[ -f "$bundle_dir/untracked.tar" ]] && tar_args+=(untracked.tar)

  tar -cf "$bundle_tar" -C "$bundle_dir" "${tar_args[@]}"
  printf '%s\n%s\n' "$bundle_tar" "$has_local_state"
}

trap cleanup_on_exit EXIT

# ---- Prerequisites ----

command -v ssh &>/dev/null || die "ssh is required but not found in PATH"

# ---- Usage ----

if [[ $# -eq 0 ]]; then
  cat >&2 << 'USAGE'
Usage: torque-remote [--branch <ref>] <command...>

Routes commands to the configured remote workstation via SSH.
Falls back to local execution if the remote is unreachable or overloaded.

Examples:
  torque-remote npx vitest run server/tests/foo.test.js
  torque-remote --branch wip/experiment npx vitest run
  torque-remote dotnet build example-project.sln
  torque-remote cargo test --release

Config: ~/.torque-remote.json + ~/.torque-remote.local.json
Override: .torque-remote.json in project root
USAGE
  exit 1
fi

# Parse leading torque-remote flags. Supported: --branch <ref>, --suite <name>.
# Both are optional. Anything else starting with -- is a user error — surface
# it rather than forwarding to the inner command (a typo like --cwd would
# otherwise silently slip into COMMAND_ARGS and the local-fallback path
# would try to exec it as a program with the cryptic "command not found").
BRANCH_OVERRIDE=""
SUITE="${TORQUE_REMOTE_DEFAULT_SUITE:-custom}"
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --branch)
      [[ $# -lt 2 ]] && die "Invalid --branch value: "
      BRANCH_OVERRIDE="$2"
      if [[ ! "$BRANCH_OVERRIDE" =~ ^[a-zA-Z0-9_./-]+$ ]]; then
        die "Invalid --branch value: $BRANCH_OVERRIDE"
      fi
      shift 2
      ;;
    --suite)
      [[ $# -lt 2 ]] && die "Invalid --suite value: "
      SUITE="$2"
      shift 2
      ;;
    *)
      die "Unknown torque-remote flag: $1
torque-remote supports --branch <ref> and --suite <name>. If $1 is meant for
your inner command, place it after the command name, e.g.:
  torque-remote npx vitest run $1 ..."
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  cat >&2 << 'USAGE'
Usage: torque-remote [--branch <ref>] <command...>

Routes commands to the configured remote workstation via SSH.
Falls back to local execution if the remote is unreachable or overloaded.

Examples:
  torque-remote npx vitest run server/tests/foo.test.js
  torque-remote --branch wip/experiment npx vitest run
  torque-remote dotnet build example-project.sln
  torque-remote cargo test --release

Config: ~/.torque-remote.json + ~/.torque-remote.local.json
Override: .torque-remote.json in project root
USAGE
  exit 1
fi

# ---- Project root detection ----

find_project_root() {
  # Walk up looking for .git. In a normal checkout, .git is a directory.
  # In a git worktree, .git is a *file* containing `gitdir: <path>`. Use
  # `-e` so worktrees stop at their own root instead of walking up to the
  # parent main checkout (where branch-detection then misreports the
  # worktree as being on `main`).
  local dir="$PWD"
  while [[ "$dir" != "/" && "$dir" != "" ]]; do
    if [[ -e "$dir/.git" ]]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}

PROJECT_ROOT="$(find_project_root)"

# When invoked from a git worktree, basename(PROJECT_ROOT) is the worktree dir
# name (e.g. "feat-x"), not the project name. That breaks any remote path
# derivation that expects a stable per-project label — <root>\<project> silently
# becomes <root>\feat-x, which the remote workstation has never created. Use
# `git rev-parse --git-common-dir` to locate the main repo: it returns ".git"
# (relative) in a regular checkout and an absolute path to the main .git dir in
# a worktree, so the parent of that path is the main repo root regardless of
# which worktree we're invoked from.
PROJECT_NAME="$(basename "$PROJECT_ROOT")"
common_dir="$(cd "$PROJECT_ROOT" 2>/dev/null && git rev-parse --git-common-dir 2>/dev/null || true)"
if [[ -n "$common_dir" ]]; then
  case "$common_dir" in
    .git|.git/) ;;  # main checkout — keep PROJECT_ROOT's basename
    *)
      case "$common_dir" in
        /*|[A-Za-z]:[\\/]*) main_git_dir="$common_dir" ;;
        *)                  main_git_dir="$PROJECT_ROOT/$common_dir" ;;
      esac
      main_repo_root="$(dirname "$main_git_dir")"
      if [[ -n "$main_repo_root" && "$main_repo_root" != "/" && "$main_repo_root" != "." ]]; then
        PROJECT_NAME="$(basename "$main_repo_root")"
      fi
      ;;
  esac
fi

# ---- Load config ----

TRANSPORT="local"
SYNC_BEFORE_RUN="true"
TIMEOUT_SECONDS="300"
LOAD_THRESHOLD="80"

# Global config
GLOBAL_CONFIG="$HOME/.torque-remote.json"
if [[ -f "$GLOBAL_CONFIG" ]]; then
  v=$(json_get "$GLOBAL_CONFIG" '.transport');        [[ -n "$v" ]] && TRANSPORT="$v"
  v=$(json_get "$GLOBAL_CONFIG" '.sync_before_run');  [[ -n "$v" ]] && SYNC_BEFORE_RUN="$v"
  v=$(json_get "$GLOBAL_CONFIG" '.timeout_seconds');  [[ -n "$v" ]] && TIMEOUT_SECONDS="$v"
  v=$(json_get "$GLOBAL_CONFIG" '.load_threshold');   [[ -n "$v" ]] && LOAD_THRESHOLD="$v"
fi

# Per-project override
PROJECT_CONFIG="$PROJECT_ROOT/.torque-remote.json"
if [[ -f "$PROJECT_CONFIG" ]]; then
  v=$(json_get "$PROJECT_CONFIG" '.transport');        [[ -n "$v" ]] && TRANSPORT="$v"
  v=$(json_get "$PROJECT_CONFIG" '.sync_before_run');  [[ -n "$v" ]] && SYNC_BEFORE_RUN="$v"
  v=$(json_get "$PROJECT_CONFIG" '.timeout_seconds');  [[ -n "$v" ]] && TIMEOUT_SECONDS="$v"
  v=$(json_get "$PROJECT_CONFIG" '.load_threshold');   [[ -n "$v" ]] && LOAD_THRESHOLD="$v"
fi

# No config at all
if [[ ! -f "$GLOBAL_CONFIG" && ! -f "$PROJECT_CONFIG" ]]; then
  warn "No .torque-remote.json found — running locally"
  TRANSPORT="local"
fi

# ---- Load connection details ----

SSH_HOST=""
SSH_USER=""
SSH_KEY_PATH=""
DEFAULT_PROJECT_PATH=""
REMOTE_PROJECT_PATH=""
# When set (relative path under REMOTE_PROJECT_PATH), torque-remote runs the
# user command inside a dedicated git worktree at that subpath instead of
# in the main checkout. Isolates concurrent Codex/local sessions on the
# remote that commit to the same repo from being clobbered by sync's
# `git reset --hard`. Bootstrapped on first use; node_modules live AT the
# subpath, so the operator must `npm ci` (in dashboard/ and server/)
# inside the worktree once after bootstrap. Disabled by default — opt in
# via .torque-remote.local.json:
#   { "remote_test_worktree_subdir": ".worktrees/torque-remote-tests" }
REMOTE_TEST_WORKTREE_SUBDIR=""
# When set (absolute path), torque-remote registers the test worktree at
# <ROOT>\<PROJECT_NAME> instead of nesting it inside the project. Saves
# ~70 chars of MAX_PATH headroom on Windows and avoids collisions when the
# project itself has a `.worktrees/` directory. Takes precedence over
# REMOTE_TEST_WORKTREE_SUBDIR when both are set. Opt in via:
#   { "remote_test_worktree_root": "C:/trt" }
REMOTE_TEST_WORKTREE_ROOT=""

# Global local config
GLOBAL_LOCAL="$HOME/.torque-remote.local.json"
if [[ -f "$GLOBAL_LOCAL" ]]; then
  SSH_HOST=$(json_get "$GLOBAL_LOCAL" '.host')
  SSH_USER=$(json_get "$GLOBAL_LOCAL" '.user')
  SSH_KEY_PATH=$(json_get "$GLOBAL_LOCAL" '.key_path')
  DEFAULT_PROJECT_PATH=$(json_get "$GLOBAL_LOCAL" '.default_project_path')
  v=$(json_get "$GLOBAL_LOCAL" '.remote_test_worktree_subdir'); [[ -n "$v" ]] && REMOTE_TEST_WORKTREE_SUBDIR="$v"
  v=$(json_get "$GLOBAL_LOCAL" '.remote_test_worktree_root');    [[ -n "$v" ]] && REMOTE_TEST_WORKTREE_ROOT="$v"
fi

# Per-project local override
PROJECT_LOCAL="$PROJECT_ROOT/.torque-remote.local.json"
if [[ -f "$PROJECT_LOCAL" ]]; then
  v=$(json_get "$PROJECT_LOCAL" '.host');                       [[ -n "$v" ]] && SSH_HOST="$v"
  v=$(json_get "$PROJECT_LOCAL" '.user');                       [[ -n "$v" ]] && SSH_USER="$v"
  v=$(json_get "$PROJECT_LOCAL" '.key_path');                   [[ -n "$v" ]] && SSH_KEY_PATH="$v"
  v=$(json_get "$PROJECT_LOCAL" '.remote_project_path');        [[ -n "$v" ]] && REMOTE_PROJECT_PATH="$v"
  v=$(json_get "$PROJECT_LOCAL" '.remote_test_worktree_subdir'); [[ -n "$v" ]] && REMOTE_TEST_WORKTREE_SUBDIR="$v"
  v=$(json_get "$PROJECT_LOCAL" '.remote_test_worktree_root');   [[ -n "$v" ]] && REMOTE_TEST_WORKTREE_ROOT="$v"
fi

# Derive remote project path if not explicitly set
if [[ -z "$REMOTE_PROJECT_PATH" && -n "$DEFAULT_PROJECT_PATH" ]]; then
  REMOTE_PROJECT_PATH="${DEFAULT_PROJECT_PATH}\\${PROJECT_NAME}"
fi

# When a test worktree is configured, all sync/test/cleanup operations run
# in the dedicated worktree instead of the main checkout. Codex sessions
# running directly on the remote workstation can keep their main checkout
# (with WIP commits, stashes, working-tree edits) without being clobbered
# by torque-remote's `git reset --hard`.
#
# REMOTE_TEST_WORKTREE_ROOT (absolute path) takes precedence and gives the
# shortest path: <ROOT>\<PROJECT_NAME>. REMOTE_TEST_WORKTREE_SUBDIR (legacy)
# nests under the project: <REMOTE_PROJECT_PATH>\<SUBDIR>. The bootstrap
# step in the sync block creates the worktree if missing.
EFFECTIVE_REMOTE_PROJECT_PATH="$REMOTE_PROJECT_PATH"
if [[ -n "$REMOTE_TEST_WORKTREE_ROOT" ]]; then
  # Normalize forward slashes to backslashes so Windows-style joining works
  # whether the user writes "C:/trt" or "C:\\trt" in JSON.
  ROOT_NORM="${REMOTE_TEST_WORKTREE_ROOT//\//\\}"
  case "$ROOT_NORM" in
    *\\) EFFECTIVE_REMOTE_PROJECT_PATH="${ROOT_NORM}${PROJECT_NAME}" ;;
    *)   EFFECTIVE_REMOTE_PROJECT_PATH="${ROOT_NORM}\\${PROJECT_NAME}" ;;
  esac
elif [[ -n "$REMOTE_TEST_WORKTREE_SUBDIR" && -n "$REMOTE_PROJECT_PATH" ]]; then
  case "$REMOTE_PROJECT_PATH" in
    *\\) EFFECTIVE_REMOTE_PROJECT_PATH="${REMOTE_PROJECT_PATH}${REMOTE_TEST_WORKTREE_SUBDIR}" ;;
    *)   EFFECTIVE_REMOTE_PROJECT_PATH="${REMOTE_PROJECT_PATH}\\${REMOTE_TEST_WORKTREE_SUBDIR}" ;;
  esac
fi

# ---- Command to run ----

COMMAND_ARGS=("$@")
COMMAND_DISPLAY="$(format_command_for_log "${COMMAND_ARGS[@]}")"

# ---- Execute ----

# ─── Coord acquire (best-effort, opt-in via --suite) ───────────────────
# When --suite is set to anything other than "custom", attempt to acquire a
# lock from the torque-coord daemon. If the daemon is unreachable or the
# lock is held by someone else, follow the wait flow. Daemon-down (CLI exit
# 2) degrades to uncoordinated execution. The EXIT trap below ensures we
# always release the lock if we acquired one, regardless of which transport
# branch exits the script.
COORD_ACQUIRED=0
COORD_LOCK_ID=""
COORD_PROJECT="$PROJECT_NAME"
COORD_SHA="${BRANCH_OVERRIDE:-$(git rev-parse HEAD 2>/dev/null || echo unknown)}"

COORD_MAX_ACQUIRE_ATTEMPTS=50

COORD_LOCAL_HASHES=""
coord_compute_local_hashes() {
  if [[ -n "$COORD_LOCAL_HASHES" ]]; then return; fi
  local out
  out=$(node "$SCRIPT_DIR/torque-coord-client" lock-hashes --root "$PROJECT_ROOT" 2>/dev/null) || out="{}"
  COORD_LOCAL_HASHES="$out"
}

coord_hashes_match() {
  # $1: stored hashes JSON (from a result record)
  # Returns 0 (match) iff every key in stored matches the same key in local.
  # An empty stored map matches anything (back-compat with Phase-1 records).
  coord_compute_local_hashes
  node -e '
    const stored = JSON.parse(process.argv[1] || "{}");
    const local = JSON.parse(process.argv[2] || "{}");
    const storedKeys = Object.keys(stored);
    if (storedKeys.length === 0) process.exit(0);
    for (const k of storedKeys) {
      if (local[k] !== stored[k]) process.exit(1);
    }
    process.exit(0);
  ' "$1" "$COORD_LOCAL_HASHES" >/dev/null 2>&1
}

coord_check_warm_hit() {
  # Returns 0 (and prints the hit's output_tail to stdout, exits the script
  # with the hit's exit_code) when there's a fresh, hash-matching cached
  # result for our (project, sha, suite). Returns 1 otherwise.
  local hit_output rc
  hit_output=$(node "$SCRIPT_DIR/torque-coord-client" results \
    --project "$COORD_PROJECT" --sha "$COORD_SHA" --suite "$SUITE" 2>/dev/null)
  rc=$?
  if [[ $rc -ne 0 ]]; then return 1; fi
  if echo "$hit_output" | grep -q '"hit":false'; then return 1; fi
  local stored_hashes hit_exit hit_tail
  stored_hashes=$(node -e '
    try {
      const r = JSON.parse(process.argv[1]);
      process.stdout.write(JSON.stringify(r.package_lock_hashes || {}));
    } catch { process.stdout.write("{}"); }
  ' "$hit_output" 2>/dev/null)
  if ! coord_hashes_match "$stored_hashes"; then
    echo "[torque-coord] hash mismatch on cached result, running fresh" >&2
    return 1
  fi
  hit_exit=$(node -e '
    try { process.stdout.write(String(JSON.parse(process.argv[1]).exit_code ?? 1)); }
    catch { process.stdout.write("1"); }
  ' "$hit_output" 2>/dev/null)
  hit_tail=$(node -e '
    try { process.stdout.write(JSON.parse(process.argv[1]).output_tail || ""); }
    catch { process.stdout.write(""); }
  ' "$hit_output" 2>/dev/null)
  echo "[torque-coord] cache hit — replaying stored result (exit $hit_exit)" >&2
  printf "%s" "$hit_tail"
  exit "$hit_exit"
}

coord_attempt_acquire() {
  local attempt=${1:-1}
  if (( attempt > COORD_MAX_ACQUIRE_ATTEMPTS )); then
    echo "[torque-coord] giving up after $COORD_MAX_ACQUIRE_ATTEMPTS attempts; running uncoordinated" >&2
    return 1
  fi
  local attempt_output rc
  attempt_output=$(node "$SCRIPT_DIR/torque-coord-client" acquire \
    --project "$COORD_PROJECT" --sha "$COORD_SHA" --suite "$SUITE" 2>/dev/null)
  rc=$?
  if [[ $rc -eq 2 ]]; then
    echo "[torque-coord] unreachable, running uncoordinated" >&2
    return 1
  fi
  if [[ $rc -eq 0 ]]; then
    COORD_LOCK_ID=$(echo "$attempt_output" | sed -n 's/.*"lock_id":"\([^"]*\)".*/\1/p')
    if [[ -z "$COORD_LOCK_ID" ]]; then
      echo "[torque-coord] acquire returned 200 but no lock_id parsed; running uncoordinated" >&2
      return 1
    fi
    COORD_ACQUIRED=1
    return 0
  fi
  if [[ $rc -eq 3 ]]; then
    local wait_for
    wait_for=$(echo "$attempt_output" | sed -n 's/.*"wait_for":"\([^"]*\)".*/\1/p')
    if [[ -n "$wait_for" ]]; then
      echo "[torque-coord] waiting for in-flight run ($wait_for, attempt $attempt)…" >&2
      node "$SCRIPT_DIR/torque-coord-client" wait --lock-id "$wait_for" >/dev/null 2>&1 || true
      # The holder just released — they may have written a result for our
      # exact (project, sha, suite). Re-check before paying for our own run.
      coord_check_warm_hit || true
      coord_attempt_acquire $((attempt + 1))
      return $?
    fi
    echo "[torque-coord] queued (global semaphore full, attempt $attempt); waiting…" >&2
    sleep 5
    coord_attempt_acquire $((attempt + 1))
    return $?
  fi
  echo "[torque-coord] unexpected exit $rc, running uncoordinated" >&2
  return 1
}

coord_release_on_exit() {
  local final_exit=$?
  if [[ "$COORD_ACQUIRED" -eq 1 && -n "$COORD_LOCK_ID" ]]; then
    coord_compute_local_hashes
    node "$SCRIPT_DIR/torque-coord-client" release \
      --lock-id "$COORD_LOCK_ID" \
      --exit "$final_exit" \
      --status "$([[ $final_exit -eq 0 ]] && echo pass || echo fail)" \
      --tail "" \
      --hashes "$COORD_LOCAL_HASHES" \
      >/dev/null 2>&1 || true
  fi
  # Chain through to the original cleanup. bash's trap is single-slot, so
  # installing this trap REPLACED the pre-existing `trap cleanup_on_exit EXIT`
  # at line ~264. Without this call, every coord-mode run skips temp-dir
  # cleanup, the orphan-tarball sweep, and remote-side cleanup — re-introducing
  # the documented 150 GB orphan accumulation regression.
  cleanup_on_exit
}

if [[ "$SUITE" != "custom" ]]; then
  trap coord_release_on_exit EXIT
  coord_check_warm_hit || true
  # If coord_check_warm_hit found a hit it would have exit'd; falling through
  # means cache miss or coord unreachable → proceed to acquire.
  coord_attempt_acquire || true
fi
# ────────────────────────────────────────────────────────────────────────

case "$TRANSPORT" in

  local)
    info "Running locally: $COMMAND_DISPLAY"
    cd "$PROJECT_ROOT"
    set +e
    "${COMMAND_ARGS[@]}"
    exit_code=$?
    set -e
    exit $exit_code
    ;;

  ssh)
    cd "$PROJECT_ROOT"

    # Validate connection details
    [[ -z "$SSH_HOST" ]] && die "SSH transport requires 'host' in ~/.torque-remote.local.json"
    [[ -z "$SSH_USER" ]] && die "SSH transport requires 'user' in ~/.torque-remote.local.json"
    [[ -z "$REMOTE_PROJECT_PATH" ]] && die "Cannot derive remote project path. Set 'default_project_path' in ~/.torque-remote.local.json or 'remote_project_path' in project .torque-remote.local.json"

    # SSH options
    SSH_OPTS=(-o ConnectTimeout=5 -o BatchMode=yes)
    if [[ -n "$SSH_KEY_PATH" && "$SSH_KEY_PATH" != "null" ]]; then
      SSH_OPTS+=(-i "$SSH_KEY_PATH")
    fi

    # Connectivity check
    if ! ssh "${SSH_OPTS[@]}" "$SSH_USER@$SSH_HOST" "echo ok" &>/dev/null; then
      warn "Remote $SSH_HOST unreachable — falling back to local"
      cd "$PROJECT_ROOT"
      set +e
      "${COMMAND_ARGS[@]}"
      exit_code=$?
      set -e
      exit $exit_code
    fi

    # Load check (Windows: wmic, Linux: /proc/loadavg)
    load_pct=""
    load_output=$(ssh -o ConnectTimeout=2 "${SSH_OPTS[@]}" "$SSH_USER@$SSH_HOST" "wmic cpu get loadpercentage /value" 2>/dev/null || true)
    if [[ -n "$load_output" ]]; then
      load_pct=$(echo "$load_output" | grep -oP 'LoadPercentage=\K[0-9]+' 2>/dev/null || true)
    fi
    if [[ -z "$load_pct" ]]; then
      # Try Linux
      load_output=$(ssh -o ConnectTimeout=2 "${SSH_OPTS[@]}" "$SSH_USER@$SSH_HOST" "cat /proc/loadavg" 2>/dev/null || true)
      if [[ -n "$load_output" ]]; then
        load_1m=$(echo "$load_output" | awk '{print $1}')
        ncpu=$(ssh -o ConnectTimeout=2 "${SSH_OPTS[@]}" "$SSH_USER@$SSH_HOST" "nproc" 2>/dev/null || echo "1")
        load_pct=$(awk "BEGIN {printf \"%.0f\", ($load_1m / $ncpu) * 100}")
      fi
    fi

    if [[ -n "$load_pct" ]] && (( load_pct > LOAD_THRESHOLD )); then
      warn "Remote $SSH_HOST is overloaded (${load_pct}% CPU, threshold ${LOAD_THRESHOLD}%) — falling back to local"
      cd "$PROJECT_ROOT"
      set +e
      "${COMMAND_ARGS[@]}"
      exit_code=$?
      set -e
      exit $exit_code
    fi

    SYNC_REF=""
    SYNC_BRANCH=""
    APPLY_LOCAL_STATE="false"
    LOCAL_STATE_BUNDLE=""

    # Sync
    if [[ "$SYNC_BEFORE_RUN" == "true" ]]; then
      if [[ -n "$BRANCH_OVERRIDE" ]]; then
        if ! git rev-parse --verify "origin/$BRANCH_OVERRIDE" >/dev/null 2>&1; then
          die "Branch '$BRANCH_OVERRIDE' does not exist on origin"
        fi
        SYNC_REF="origin/$BRANCH_OVERRIDE"
      else
        local_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "HEAD")
        if [[ "$local_branch" == "HEAD" ]]; then
          SYNC_REF="$(resolve_sync_ref "")" || die "Could not resolve a remote base ref for detached HEAD"
        elif [[ "$local_branch" =~ ^[a-zA-Z0-9_./-]+$ ]]; then
          SYNC_REF="$(resolve_sync_ref "$local_branch")" || die "Could not resolve a remote base ref for '$local_branch'"
        else
          warn "Branch name contains unsafe characters — falling back to default origin branch"
          SYNC_REF="$(resolve_sync_ref "")" || die "Could not resolve a remote base ref for '$local_branch'"
        fi

      fi

      SYNC_BRANCH="${SYNC_REF#origin/}"
      info "Syncing $SYNC_BRANCH on remote..."
      # When the test-worktree subdir is configured, ensure the worktree
      # exists before sync. We register it from the MAIN checkout (the only
      # place git's worktree metadata lives) and then the sync below runs
      # entirely inside the worktree, leaving the main checkout's HEAD,
      # stash, and working-tree edits untouched.
      SYNC_BOOTSTRAP=""
      # In worktree mode, the named branch (e.g. master) is owned by the
      # main checkout, so `git checkout --force <branch>` would fail with
      # "already used by worktree at <main path>". Use detached HEAD on the
      # remote ref instead — branch identity isn't needed for build/test.
      if [[ "$EFFECTIVE_REMOTE_PROJECT_PATH" != "$REMOTE_PROJECT_PATH" ]]; then
        # CMD-compatible bootstrap. The ssh command runs in CMD on Windows
        # (no grep, no test, no posix). Use CMD's `if not exist DIR (...)`
        # to short-circuit when the worktree already exists; first run does
        # the `git worktree add` from main checkout. `2>nul` swallows any
        # "already used" message in the rare case dir exists but git's
        # metadata is stale. `cd /d` is required for ROOT-mode worktrees that
        # may live on a different drive than the project.
        # `git config core.longpaths=true` runs every sync (idempotent) so
        # that nested project tooling (StateTrace's own .worktrees, Unity
        # build outputs, etc.) doesn't trip Windows MAX_PATH=260. Git uses
        # the \\?\-prefixed Win32 API when this is on, raising the ceiling
        # to ~32K characters.
        SYNC_BOOTSTRAP="if not exist \"$EFFECTIVE_REMOTE_PROJECT_PATH\\.git\" (cd /d \"$REMOTE_PROJECT_PATH\" && git worktree add --force \"$EFFECTIVE_REMOTE_PROJECT_PATH\" $SYNC_REF 2>nul) && cd /d \"$EFFECTIVE_REMOTE_PROJECT_PATH\" && git config core.longpaths true && "
        SYNC_CHECKOUT="git checkout --force --detach $SYNC_REF"
      else
        SYNC_CHECKOUT="git checkout --force $SYNC_BRANCH"
      fi
      # Filter sync output through grep but tolerate empty input (grep
      # returns 1 with no matches; we don't want that to look like sync
      # failure). Track ssh's actual exit status via PIPESTATUS.
      # `git clean -fd` removes untracked files so subsequent patch overlays
      # apply cleanly — without it, files left behind by a killed prior run
      # cause `git apply` to fail with "already exists in working directory".
      # Best-effort `|| true` keeps clean failures (e.g. permission-denied
      # subdirs) from masquerading as sync failures.
      #
      # Drift check: on Windows, file locks held by Defender/Search-indexer/
      # antivirus can cause `git checkout --force` and `git reset --hard` to
      # silently leave individual files at their old content while still
      # exiting 0. A subsequent `git diff --quiet HEAD` catches that drift
      # — if any tracked file diverged from the new HEAD, exit 99 so the
      # outer sync_status check fires and surfaces the failure instead of
      # quietly running tests against half-updated code.
      #
      # node_modules hint: torque-remote doesn't auto-install npm deps, so a
      # freshly-registered REMOTE_TEST_WORKTREE_ROOT (or any worktree where
      # `npm install` was forgotten) silently fails the user command later
      # with MODULE_NOT_FOUND. After sync we cmd-`if exist` check the most
      # common Node.js layouts (root, server/, dashboard/) and emit a hint
      # to stderr when package.json has no node_modules sibling. Hardcoded
      # subdir names work for monorepo conventions; non-Node projects skip
      # silently because `if exist <pj>` is false. Each block is wrapped in
      # `(...)` so a missing subdir doesn't break the && chain — cmd's
      # `if not exist` returns 0 even when the condition was false.
      sync_status=0
      sync_log_path="${TORQUE_REMOTE_SYNC_LOG:-/tmp/torque-remote-sync.log}"
      # `git clean -fd` (no -x) was `-fdx` until 2026-04-27. The -x flag
      # removes gitignored files — including node_modules. On Windows, that
      # tear-down/rebuild churn cost ~15s per sync (Defender re-scans tens
      # of thousands of node_modules entries each cycle), and operators had
      # to re-run `npm install` between every sync since gitignored deps got
      # wiped. Dropping -x preserves node_modules across syncs; tracked-file
      # cleanup still runs via -fd, which removes only untracked files left
      # by killed prior runs. The first-sync npm-install hints below still
      # fire correctly when node_modules genuinely doesn't exist.
      #
      # `git fetch --prune` removes remotes/origin/* refs that origin no
      # longer advertises. Without --prune, every pre-push-gate/<sha>
      # staging ref (created and then deleted from origin by the pre-push
      # hook) leaves a permanent local entry. Measured 2026-04-27: 43 stale
      # pre-push-gate refs + ~80 other dead branches accumulated, bringing
      # total refs to 587 and doubling the worktree-lifecycle perf metric
      # (149→299ms) because git iterates all refs for branch-ambiguity
      # checks on every `git worktree add`. After pruning, the metric
      # dropped to 131ms (better than the original baseline). --prune adds
      # no measurable overhead to fetch itself.
      ssh "${SSH_OPTS[@]}" "$SSH_USER@$SSH_HOST" \
        "${SYNC_BOOTSTRAP}cd \"$EFFECTIVE_REMOTE_PROJECT_PATH\" && git fetch --prune origin && $SYNC_CHECKOUT && git reset --hard $SYNC_REF && (git clean -fd || true) && (git diff --quiet HEAD || (echo \"[torque-remote-sync] drift after reset — file locks (Defender/Search/AV) may have prevented checkout from updating tracked files\" 1>&2 && exit 99)) && (if exist package.json if not exist node_modules echo [torque-remote-sync] HINT: ./package.json has no node_modules at $EFFECTIVE_REMOTE_PROJECT_PATH — run: npm install 1>&2) && (if exist server\\package.json if not exist server\\node_modules echo [torque-remote-sync] HINT: server/package.json has no node_modules — run: cd server ^&^& npm install 1>&2) && (if exist dashboard\\package.json if not exist dashboard\\node_modules echo [torque-remote-sync] HINT: dashboard/package.json has no node_modules — run: cd dashboard ^&^& npm install 1>&2)" \
        2>&1 | tee -a "$sync_log_path" | (grep -v 'Unable to persist credentials\|credential store\|aka.ms/gcm' || true) || sync_status="${PIPESTATUS[0]}"
      if [[ "$sync_status" -ne 0 ]]; then
        # Sync failed — falling back to local execution rather than running
        # against stale or wrong-base remote state. The drift-detection exit
        # 99 (file lock during checkout) and any other non-zero ssh exit both
        # land here. Live regression 2026-04-25: torque-public's remote test
        # worktree silently stayed at an old commit for 24h because sync
        # warned but proceeded; the LLM verify-reviewer then hallucinated
        # "patch overlay conflicts" against the stale state.
        warn "Sync failed (status=$sync_status) — falling back to local (see $sync_log_path)"
        cd "$PROJECT_ROOT"
        set +e
        "${COMMAND_ARGS[@]}"
        exit_code=$?
        set -e
        exit $exit_code
      fi
    fi

    GIT_BASH='C:\progra~1\Git\bin\bash.exe'
    COMMAND_ARGS_LITERAL="$(bash_array_literal COMMAND_ARGS "${COMMAND_ARGS[@]}")"

    # runner.sh body — executed on remote inside the bundle's extracted dir.
    # Reads local patches/untracked tar (if present in the bundle) and runs the user command.
    REMOTE_RUN_BODY=$(cat <<EOF
# torque-remote-inline-run
PROJECT_PATH=$(shell_quote "$EFFECTIVE_REMOTE_PROJECT_PATH")
SYNC_REF=$(shell_quote "$SYNC_REF")
BUNDLE_DIR="\$(cd "\$(dirname "\$0")" && pwd)"
$COMMAND_ARGS_LITERAL
set -euo pipefail
cd "\$PROJECT_PATH"
APPLIED_LOCAL_STATE="false"
cleanup() {
  if [[ "\$APPLIED_LOCAL_STATE" == "true" ]]; then
    git reset --hard "\$SYNC_REF" >/dev/null 2>&1 || true
    git clean -fd >/dev/null 2>&1 || true
  fi
}
trap cleanup EXIT
if [[ -s "\$BUNDLE_DIR/committed.patch" ]]; then
  git apply --binary --3way "\$BUNDLE_DIR/committed.patch"
  APPLIED_LOCAL_STATE="true"
fi
if [[ -s "\$BUNDLE_DIR/worktree.patch" ]]; then
  git apply --binary --3way "\$BUNDLE_DIR/worktree.patch"
  APPLIED_LOCAL_STATE="true"
fi
if [[ -f "\$BUNDLE_DIR/untracked.tar" ]]; then
  tar -xf "\$BUNDLE_DIR/untracked.tar" -C .
  APPLIED_LOCAL_STATE="true"
fi
"\${COMMAND_ARGS[@]}"
EOF
)

    # Always bundle runner.sh + (maybe) patches/untracked into a tar delivered via SSH stdin.
    # --branch <ref> explicitly requests the remote ref as-is; don't overlay local state there.
    if [[ -n "$BRANCH_OVERRIDE" ]]; then
      CAPTURE_LOCAL_STATE="false"
    else
      CAPTURE_LOCAL_STATE="true"
    fi
    BUNDLE_OUTPUT="$(create_local_state_bundle "$SYNC_REF" "$REMOTE_RUN_BODY" "$CAPTURE_LOCAL_STATE")"
    LOCAL_STATE_BUNDLE="$(printf '%s' "$BUNDLE_OUTPUT" | sed -n '1p')"
    APPLY_LOCAL_STATE="$(printf '%s' "$BUNDLE_OUTPUT" | sed -n '2p')"

    if [[ "$APPLY_LOCAL_STATE" == "true" ]]; then
      if [[ "$SYNC_REF" != "origin/${local_branch:-}" ]]; then
        info "Branch '${local_branch:-HEAD}' is not on origin; using ${SYNC_REF#origin/} as the remote base and overlaying local worktree state"
      else
        info "Overlaying local worktree state on top of ${SYNC_REF#origin/}"
      fi
    fi

    # Minimal cmd.exe-safe bootstrap. No newlines, no internal double quotes, no backslash-escaped
    # quotes (cmd.exe would mis-parse). Extracts the tar from SSH stdin, runs runner.sh, propagates rc.
    REMOTE_RUN_COMMAND="\"$GIT_BASH\" -lc \"d=\$(mktemp -d);tar -xf - -C \$d;bash \$d/runner.sh;rc=\$?;rm -rf \$d;exit \$rc\""
    REMOTE_CLEANUP_BODY=$(cat <<EOF
# torque-remote-failsafe-cleanup
cd $(shell_quote "$EFFECTIVE_REMOTE_PROJECT_PATH") || exit 0
if [[ $(shell_quote "$APPLY_LOCAL_STATE") == 'true' ]]; then
  git reset --hard $(shell_quote "$SYNC_REF") >/dev/null 2>&1 || true
  git clean -fd >/dev/null 2>&1 || true
fi
EOF
)
    REMOTE_CLEANUP_COMMAND="\"$GIT_BASH\" -lc $(shell_quote "$REMOTE_CLEANUP_BODY")"
    REMOTE_CLEANUP_REQUIRED="$APPLY_LOCAL_STATE"

    info "Running on $SSH_USER@$SSH_HOST: $COMMAND_DISPLAY"
    set +e
    run_with_timeout "$TIMEOUT_SECONDS" ssh "${SSH_OPTS[@]}" "$SSH_USER@$SSH_HOST" \
      "$REMOTE_RUN_COMMAND" < "$LOCAL_STATE_BUNDLE"
    exit_code=$?
    set -e

    if [[ "$APPLY_LOCAL_STATE" == "true" ]]; then
      case "$exit_code" in
        124|255)
          cleanup_remote_exec
          ;;
        *)
          REMOTE_CLEANUP_REQUIRED="false"
          ;;
      esac
    else
      REMOTE_CLEANUP_REQUIRED="false"
    fi

    if [[ $exit_code -eq 124 ]]; then
      echo "[torque-remote] ERROR: Command timed out after ${TIMEOUT_SECONDS}s" >&2
    fi
    exit $exit_code
    ;;

  *)
    die "Unknown transport '$TRANSPORT'. Valid: local, ssh"
    ;;
esac
