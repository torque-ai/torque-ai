#!/usr/bin/env bash

# torque-remote-guard — Claude Code PreToolUse hook for Bash tool.
# Intercepts heavy commands and redirects to torque-remote.
#
# Exit 0: allow
# Exit 2: block with redirect message

# ---- Find project root ----

find_project_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" && "$dir" != "" ]]; do
    if [[ -d "$dir/.git" ]]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}

PROJECT_ROOT="$(find_project_root)"

# ---- Load config ----

CONFIG=""
if [[ -f "$PROJECT_ROOT/.torque-remote.json" ]]; then
  CONFIG="$PROJECT_ROOT/.torque-remote.json"
elif [[ -f "$HOME/.torque-remote.json" ]]; then
  CONFIG="$HOME/.torque-remote.json"
fi

# No config → allow everything
if [[ -z "$CONFIG" ]]; then
  exit 0
fi

# Check jq
if ! command -v jq &>/dev/null; then
  echo "[torque-remote-guard] WARNING: jq not found, guard disabled" >&2
  exit 0
fi

# Local transport → allow everything
transport=$(jq -r '.transport // "local"' "$CONFIG" 2>/dev/null | tr -d '\r' || echo "local")
if [[ "$transport" == "local" ]]; then
  exit 0
fi

# ---- Read command from stdin ----

input=$(cat)
command=$(echo "$input" | jq -r '.tool_input.command // empty' 2>/dev/null || echo "")

if [[ -z "$command" ]]; then
  exit 0
fi

# ---- Check first token for recursion and safe commands ----

first_token=$(echo "$command" | awk '{print $1}')
if [[ "$first_token" == "torque-remote" || "$first_token" == */torque-remote ]]; then
  exit 0
fi

# Commands that only send data to APIs — keywords in payloads aren't local execution
if [[ "$first_token" == "curl" ]]; then
  exit 0
fi

# If the command pipes through curl, keywords in -d payloads aren't local execution
if echo "$command" | grep -q 'curl '; then
  exit 0
fi

# ---- Skip git subcommands that legitimately take arbitrary text ----
#
# `git commit -m "... vitest ..."`, `git log --grep vitest`, `git show ...`
# etc. carry free-form strings as arguments. Pattern-matching them as if
# they were commands produces false positives (e.g. the literal word
# "vitest" inside a commit message).
#
# Detect the actual subcommand by walking tokens after `git`, skipping
# git's own pre-subcommand option flags (and their values where applicable).
# A naive `awk '{print $2}'` mis-reads `git -C <path> commit ...` as
# subcommand "-C" and lets the false-positive content scan run on the
# commit message body.
if [[ "$first_token" == "git" ]]; then
  IFS=' ' read -ra git_tokens <<< "$(echo "$command" | tr '\n\r' '  ')"
  git_sub=""
  gi=1  # skip "git" itself
  while (( gi < ${#git_tokens[@]} )); do
    gt="${git_tokens[$gi]}"
    case "$gt" in
      "")
        # Empty slot from double-space; skip.
        gi=$((gi + 1))
        ;;
      -C|-c|--exec-path|--git-dir|--work-tree|--namespace|--super-prefix|--config-env)
        # Takes a separate-token value; skip flag and its arg.
        gi=$((gi + 2))
        ;;
      --exec-path=*|--git-dir=*|--work-tree=*|--namespace=*|--super-prefix=*|--config-env=*)
        # Inline value form; skip just this token.
        gi=$((gi + 1))
        ;;
      -p|-P|--paginate|--no-pager|--no-replace-objects|--bare|--literal-pathspecs|--glob-pathspecs|--noglob-pathspecs|--icase-pathspecs|-h|--help|-v|--version)
        # Standalone flag with no value; skip just this token.
        gi=$((gi + 1))
        ;;
      *)
        # First non-option token is the subcommand.
        git_sub="$gt"
        break
        ;;
    esac
  done
  case "$git_sub" in
    commit|log|show|tag|blame|notes|grep|rebase|bisect|cherry-pick)
      exit 0
      ;;
  esac
fi

# ---- Load intercept patterns ----

# Read intercept_commands as newline-separated list (strip \r from Windows line endings)
patterns=$(jq -r '.intercept_commands[]? // empty' "$CONFIG" 2>/dev/null | tr -d '\r' || true)

if [[ -z "$patterns" ]]; then
  # Default patterns if not configured
  patterns="vitest
jest
pytest
mocha
dotnet test
dotnet build
dotnet publish
npm test
npm run build
npm run test
go test
go build
cargo build
cargo test
make
msbuild
tsc"
fi

# ---- Match patterns against command ----

# Tokenize the command (flatten newlines so multi-line commands are fully scanned)
IFS=' ' read -ra tokens <<< "$(echo "$command" | tr '\n\r' '  ')"

match_pattern() {
  local pattern="$1"
  local -a pat_tokens
  IFS=' ' read -ra pat_tokens <<< "$pattern"
  local pat_len=${#pat_tokens[@]}

  # Scan for consecutive token match — catches `npx vitest`, `dotnet build`, etc.
  for (( i=0; i <= ${#tokens[@]} - pat_len; i++ )); do
    local matched=true
    for (( j=0; j < pat_len; j++ )); do
      if [[ "${tokens[$((i+j))]}" != "${pat_tokens[$j]}" ]]; then
        matched=false
        break
      fi
    done
    if [[ "$matched" == "true" ]]; then
      return 0
    fi
  done

  # Path-component scan for SINGLE-WORD patterns (e.g. `vitest`, `tsc`, `jest`).
  # The consecutive-token matcher above misses bypass forms like:
  #   node node_modules/vitest/vitest.mjs run
  #   node ./node_modules/.bin/vitest run
  # because none of those tokens equals "vitest" exactly. This scan catches
  # the pattern appearing as a path component (preceded/followed by `/`, `\`,
  # `.`, or string boundary) inside any token. Multi-word patterns like
  # "dotnet build" don't need this — they're command-pair forms already.
  #
  # Boundary cases verified:
  #   "vitest"                       ✓ (start, end)
  #   "vitest.mjs"                   ✓ (start, .)
  #   "node_modules/vitest/foo.js"   ✓ (after /, before /)
  #   "/usr/local/bin/vitest"        ✓ (after /, end)
  #   "myvitest" / "vitestrun"       ✗ (no boundary on one side)
  if (( pat_len == 1 )); then
    local single="${pat_tokens[0]}"
    local token
    for token in "${tokens[@]}"; do
      if [[ "$token" =~ (^|[/\\])"$single"($|\.|[/\\]) ]]; then
        return 0
      fi
    done
  fi

  return 1
}

command_has_shell_features() {
  # Detect shell chaining/redirection — when present, prepending
  # `torque-remote` to the whole string produces a nonsensical command
  # (e.g. `torque-remote cd X && torque-remote Y` runs cd on the remote
  # but Y locally). Wrapping in `bash -c` is the only correct shape.
  local s="$1"
  [[ "$s" == *"&&"* || "$s" == *"||"* || "$s" == *";"* || "$s" == *"|"* ]] && return 0
  [[ "$s" == *">"* || "$s" == *"<"* ]] && return 0
  return 1
}

build_suggested_command() {
  local cmd="$1"
  if command_has_shell_features "$cmd"; then
    # Escape single quotes inside the user's command for safe wrapping.
    local escaped="${cmd//\'/\'\\\'\'}"
    printf "torque-remote bash -c '%s'" "$escaped"
  else
    printf "torque-remote %s" "$cmd"
  fi
}

while IFS= read -r pattern; do
  [[ -z "$pattern" ]] && continue
  if match_pattern "$pattern"; then
    suggested=$(build_suggested_command "$command")
    cat >&2 << EOF
BLOCKED: "$pattern" should run on the remote workstation.

Use:  $suggested

The remote workstation handles heavy builds/tests. If it's unreachable,
torque-remote will automatically fall back to local execution.
Chained commands (cd && X, X | Y, X > out) must be wrapped in
\`torque-remote bash -c '...'\` so the entire pipeline runs on the
remote — prepending torque-remote alone only forwards the first
clause and leaves the rest running locally.
EOF
    exit 2
  fi
done <<< "$patterns"

exit 0
