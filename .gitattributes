# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Source code
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.htm text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Config files
*.env text eol=lf
*.editorconfig text eol=lf
*.eslintrc text eol=lf
*.prettierrc text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.npmrc text eol=lf
*.nvmrc text eol=lf
.eslintrc.* text eol=lf
.prettierrc.* text eol=lf

# Shell scripts — always LF
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files — always CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Lock files
package-lock.json text eol=lf

# Binary files — do not normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.bmp binary
*.tiff binary
*.tif binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.ogg binary
*.webm binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.node binary
*.sqlite binary
*.db binary
scripts/pre-push-hook text eol=lf
