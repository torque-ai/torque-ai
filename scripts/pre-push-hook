#!/usr/bin/env bash
# Two-tier pre-push flow:
# - Pushes targeting refs/heads/main run the full dashboard + remote server gate.
# - The gate stages HEAD on a disposable `pre-push-gate/<sha>` ref so the remote
#   can sync and test *without* touching origin/main. On success, the outer
#   `git push` proceeds normally (fast-forward, no ref drift). On failure, the
#   staging ref is deleted and the push is blocked with exit 1.
# - Pushes that only update non-main refs skip tests so feature-branch iteration stays fast.
# - Delete-only pushes are always allowed and skipped from gating analysis.
# - When a branch is later merged or pushed to main, the full gate runs again there.
# - Use git push --no-verify as the escape hatch when bypassing the hook is intentional.
#
# Why staging-branch instead of pushing to origin/main up-front:
# - Previously the hook pushed HEAD to origin/main before testing (so torque-remote
#   could sync it), then rolled back on failure. That left the outer `git push`
#   to send a pack whose expected_sha no longer matched origin, producing a
#   confusing `[remote rejected] main -> main (cannot lock ref)` error and a
#   non-zero exit code even when the gate passed. Scripts doing `git push && …`
#   broke on the false failure. See project memory for the diagnosis.
# - Staging keeps origin/main immutable until the user's push lands, so exit
#   codes match reality: 0 means "gate passed AND origin/main is at HEAD", 1
#   means "gate failed AND origin/main is unchanged".
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PATH="$REPO_ROOT/bin:$PATH"
export PATH
TORQUE_REMOTE_BIN="$REPO_ROOT/bin/torque-remote"
TORQUE_REMOTE_CMD="$(printf '%q' "$TORQUE_REMOTE_BIN")"

ZERO_SHA="0000000000000000000000000000000000000000"
remote_refs=()
local_head_sha=""

# Each line is: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "$ZERO_SHA" ]; then
    # Delete-only line — ignore for gating analysis.
    continue
  fi

  already_seen=0
  for existing_ref in "${remote_refs[@]}"; do
    if [ "$existing_ref" = "$remote_ref" ]; then
      already_seen=1
      break
    fi
  done

  if [ "$already_seen" -eq 0 ]; then
    remote_refs+=("$remote_ref")
  fi

  if [ "$remote_ref" = "refs/heads/main" ]; then
    local_head_sha="$local_sha"
  fi
done

if [ "${#remote_refs[@]}" -eq 0 ]; then
  echo "[pre-push] Delete-only push, allowing."
  exit 0
fi

main_push=0
for remote_ref in "${remote_refs[@]}"; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    main_push=1
    break
  fi
done

if [ "$main_push" -eq 0 ]; then
  echo "[pre-push] Skipping tests for feature-branch push (${remote_refs[*]}). Main merges will be gated."
  exit 0
fi

if [ -z "$local_head_sha" ]; then
  echo "[pre-push] Main push detected but local sha not captured from stdin — aborting."
  exit 1
fi

# vitest writes its summary with ANSI color codes even under `--reporter=dot`,
# which causes `^[[:space:]]*Test Files` anchors to fail (the line begins with
# an ESC byte, not whitespace). Strip ANSI before matching so the grep patterns
# see the plain text they were written against. Observed 2026-04-21 when a
# "Test Files 5 failed | 18989 Tests passed" run failed to trigger the
# file-load-flake retry — the retry helper ran but `is_file_load_only_flake`
# returned false on the ANSI-wrapped output, so neither retry nor failure
# classification worked.
strip_ansi() {
  # Matches CSI sequences `ESC [ … m` — enough for vitest's color output.
  # Printed as $'\x1b' (bash ANSI-C quoting) so it works on git-bash + mac sed.
  sed $'s/\x1b\\[[0-9;]*m//g'
}

# Strip the `[dash] `/`[serv] ` line prefix added when both phases run in
# parallel inside a single SSH session. Lines without the prefix pass
# through untouched, so this is safe to apply to any output.
strip_phase_prefix() {
  sed -E 's/^\[(dash|serv)\] //'
}

# vitest prints two summary lines:
#   Test Files  1 failed | 890 passed | 4 skipped (895)
#   Tests       18564 passed | 27 skipped | 10 todo (18601)
# A file-load failure (import error, syntax) increments "Test Files failed"
# without any individual test recording as failed — so the check must match
# either line. The previous 'Tests .* failed' pattern missed this case and
# silently let pushes through with a red test file.
tests_have_failures() {
  local output="$1"
  echo "$output" | strip_ansi | strip_phase_prefix | grep -qE '^[[:space:]]*(Test Files|Tests)[[:space:]].*failed'
}

# Distinguishes real test failures (tests that ran and asserted wrong) from
# transient file-load failures (vitest's /@id/ internal module resolver
# flaking under parallel load; "N Test Files failed | 0 Tests failed").
# Real test failures should fail the gate immediately. File-load flakes
# deserve one retry before blocking.
is_file_load_only_flake() {
  local output="$1"
  local plain
  plain=$(echo "$output" | strip_ansi | strip_phase_prefix)
  # "Tests  N failed" means real assertion failures — not a flake
  if echo "$plain" | grep -qE '^[[:space:]]*Tests[[:space:]]+[0-9]+ failed'; then
    return 1
  fi
  # "Test Files N failed" with no test-level failures — likely file-load flake
  if echo "$plain" | grep -qE '^[[:space:]]*Test Files[[:space:]].*failed'; then
    return 0
  fi
  return 1
}

# Detects a native crash inside a vitest worker — broader than "segfault"
# despite the legacy name. Root cause cluster: better-sqlite3 12.x + Node 24
# + worker_threads (https://github.com/WiseLibs/better-sqlite3/issues/1376),
# libuv handle-state asserts in src\win\handle.c on async I/O races, and the
# occasional V8 abort. All three kill the vitest process before it prints a
# "Test Files" summary, so is_file_load_only_flake() can't see them. Match
# the wire-level signatures for each. Pair with the same real-failure guard
# so a crash that follows a real assertion failure doesn't get retried.
#
# Patterns (any one is sufficient):
#   - "Segmentation fault" — npx's wrapper prints this on signal 11
#   - "SIGSEGV" / "exit code 139" — alternate wordings for signal 11
#   - "Assertion failed:" + ".c, line" — libuv/V8 native asserts (e.g.
#     "Assertion failed: 0, file src\\win\\handle.c, line 71")
#   - "FATAL ERROR" — V8 fatal abort (OOM, ineffective mark-compacts, etc.)
#   - "Aborted" / "abort()" — explicit abort calls in native code
#   - "exit code 134" / "exit code 127" — common abnormal exits when the
#     shell maps a native abort to a non-zero rc on Windows. We bound this
#     to lines that ALSO contain a crash phrase, so we don't retry a
#     legitimate "command not found" 127.
is_segfault_flake() {
  local output="$1"
  local plain
  plain=$(echo "$output" | strip_ansi | strip_phase_prefix)
  if echo "$plain" | grep -qE '^[[:space:]]*Tests[[:space:]]+[0-9]+ failed'; then
    return 1
  fi
  if echo "$plain" | grep -qE 'Segmentation fault|SIGSEGV|exit code 139|exit code 134|Aborted|abort\(\)|FATAL ERROR'; then
    return 0
  fi
  # libuv-style native assertion. Restrict to .c source files so we don't
  # match incidental "Assertion failed" strings inside JS test output.
  if echo "$plain" | grep -qE 'Assertion failed:.*\.c, line [0-9]+'; then
    return 0
  fi
  return 1
}

# Detects torque-remote's explicit guard for a shared remote checkout being
# swapped between sync and command execution. This is transient when another
# already-running client does not honor the remote worktree lock; retry once
# after a short backoff instead of failing the whole push immediately.
is_remote_worktree_contamination() {
  local output="$1"
  local plain
  plain=$(echo "$output" | strip_ansi | strip_phase_prefix)
  echo "$plain" | grep -qE '\[torque-remote-sync\] worktree HEAD .*does not match .*concurrent torque-remote session likely clobbered the checkout'
}

# Returns 0 (true) if the gate-end marker reports any nonzero phase exit.
# Used to gate retry decisions independently of $RETRIED_EXIT, which is
# unreliable: under Git Bash on Windows the wait/eval/`&` pipeline
# occasionally surfaces 0 even when the inner SSH command exited nonzero
# (observed 2026-04-27: dash_exit=1 serv_exit=127 in the marker but
# RETRIED_EXIT==0, so the file-load-flake retry never fired). The marker
# is printed verbatim by the parallel-gate heredoc and is the ground truth.
gate_marker_has_failure() {
  local output="$1"
  echo "$output" | grep -qE '\[gate-end\] .*_exit=[1-9]'
}

# Per-phase timeout caps pathological SSH stalls. Empirically, dashboard
# completes in ~1m and server in ~2.5m, so 10min is a generous safety net.
PHASE_TIMEOUT_SECS="${PRE_PUSH_PHASE_TIMEOUT_SECS:-600}"

# Run a test command with one auto-retry if the only failure shape is
# file-load (see is_file_load_only_flake). Exports RETRIED_OUTPUT and
# RETRIED_EXIT so the caller can evaluate the final result.
#
# Streams output to the user's terminal in real time AND captures it to a
# tempfile for the retry/failure analysis below. We deliberately do NOT
# pipe the command into `tee`: on Git Bash + Windows, ssh leaks its stdio
# handles to a child process that doesn't release them, so `tee` never
# sees EOF on its stdin pipe and hangs indefinitely after the gate has
# already finished printing `[gate-end] dash_exit=N serv_exit=M`. The leak
# is invisible because `eval`/`ssh`/`torque-remote` have all exited — the
# only proof is `ps -ef` showing a stranded `tee`.
#
# Workaround: redirect the command to the tempfile in the background, and
# have a sibling `tail -f --pid=<eval-pid>` stream the file to stdout.
# `tail --pid` exits when the writer dies, so the streamer never outlives
# the work. The tempfile is the canonical capture; PIPESTATUS doesn't
# enter the picture.
#
# Background+wait also gives the inner command its own process group, so
# the tempfile redirect terminates cleanly the moment `wait $CMD_PID`
# returns — no fd inheritance up the chain.
run_with_flake_retry_inner() {
  local cmd="$1"
  local tmp="$2"
  local cmd_pid tail_pid
  : > "$tmp"
  eval "$cmd" > "$tmp" 2>&1 &
  cmd_pid=$!
  tail -f --pid="$cmd_pid" "$tmp" &
  tail_pid=$!
  wait "$cmd_pid"
  RETRIED_EXIT=$?
  # tail should have self-exited via --pid; reap defensively.
  wait "$tail_pid" 2>/dev/null || true

  # Wait for the tempfile to stop growing. On Git Bash + Windows, `wait`
  # can return as soon as the eval subshell exits, but the OS may still be
  # flushing the final stdio writes from the redirect. Without this quiesce
  # loop the caller can read an incomplete `$tmp` that's missing the last
  # few lines — including `[gate-end] dash_exit=N serv_exit=M` printed by
  # the parallel-gate heredoc. When that marker is missing the failure
  # attribution falls back to combined_exit and reports the wrong phase.
  # Observed today: dashboard stream kept arriving for ~3-4s after the
  # gate-end echo, pushing the marker into the long tail. The original
  # 1-second cap (5 × 200ms) wasn't enough; bumped to 30 × 200ms = 6 s.
  # If the marker is found before then, exit early to keep the hook snappy.
  local size_a size_b iter
  size_a=$(wc -c < "$tmp" 2>/dev/null || echo 0)
  for iter in $(seq 1 30); do
    sleep 0.2
    # Fast-exit once the parallel-gate marker is present — it's the only
    # parsing input we strictly need from the tail.
    # Require digits after `dash_exit=` so this regex doesn't match the
    # `[torque-remote] Running on ...` source-string log line, which echoes
    # the literal heredoc body containing `dash_exit=$DASH_EXIT` (no digits).
    # That false match was triggering fast-exit BEFORE the actual gate-end
    # marker arrived, then the parser fell back to combined_exit and reported
    # the wrong phase as failed.
    grep -qE '\[gate-end\] dash_exit=[0-9]' "$tmp" 2>/dev/null && break
    size_b=$(wc -c < "$tmp" 2>/dev/null || echo 0)
    [ "$size_a" = "$size_b" ] && break
    size_a="$size_b"
  done
}

run_with_flake_retry() {
  local label="$1"
  local cmd="$2"
  local tmp
  tmp=$(mktemp -t prepush.XXXXXX)

  set +e
  run_with_flake_retry_inner "$cmd" "$tmp"
  set -e
  RETRIED_OUTPUT=$(<"$tmp")

  # Gate retry on EITHER RETRIED_EXIT being nonzero OR the gate-end marker
  # reporting any nonzero phase exit. RETRIED_EXIT alone is unreliable on
  # Git Bash + Windows when the eval'd ssh command crashes mid-stream (the
  # 2026-04-27 measurement saw `dash_exit=1 serv_exit=127` in the marker but
  # RETRIED_EXIT==0, so neither flake retry fired). gate_marker_has_failure
  # is the ground truth; combined with the existing exit-code check it
  # belt-and-suspenders the retry trigger.
  if { [ "$RETRIED_EXIT" -ne 0 ] || gate_marker_has_failure "$RETRIED_OUTPUT"; } \
       && is_remote_worktree_contamination "$RETRIED_OUTPUT"; then
    echo "[pre-push] $label: remote worktree contamination detected -- blocking this push; wait for the conflicting sync to finish and rerun git push."
    RETRIED_EXIT=98
  elif { [ "$RETRIED_EXIT" -ne 0 ] || gate_marker_has_failure "$RETRIED_OUTPUT"; } \
       && is_file_load_only_flake "$RETRIED_OUTPUT"; then
    echo "[pre-push] $label: file-load flake detected (0 test failures, N file-load failures) — retrying once..."
    set +e
    run_with_flake_retry_inner "$cmd" "$tmp"
    set -e
    RETRIED_OUTPUT=$(<"$tmp")
  elif { [ "$RETRIED_EXIT" -ne 0 ] || gate_marker_has_failure "$RETRIED_OUTPUT"; } \
         && is_segfault_flake "$RETRIED_OUTPUT"; then
    echo "[pre-push] $label: native crash detected (segfault / libuv assert / V8 abort) — retrying once..."
    set +e
    run_with_flake_retry_inner "$cmd" "$tmp"
    set -e
    RETRIED_OUTPUT=$(<"$tmp")
  fi

  rm -f "$tmp"
}

# Disposable ref under refs/heads/pre-push-gate/. Includes the local sha plus
# a per-hook-run suffix so an older failed hook's EXIT cleanup cannot delete a
# newer attempt for the same HEAD while the newer remote sync is still fetching.
hook_run_id="$(date +%s 2>/dev/null || echo time)-$$"
staging_branch="pre-push-gate/$(echo "$local_head_sha" | cut -c1-12)-$hook_run_id"

delete_staging_ref() {
  # Best-effort cleanup — never block the hook on a failed cleanup, but log
  # so noise is visible if it starts failing.
  if ! git push --no-verify --quiet origin --delete "$staging_branch" 2>/dev/null; then
    echo "[pre-push] warn: failed to delete staging ref $staging_branch (may not exist on origin)"
  fi
}

# Always cleanup the staging ref on exit, whether we succeeded or failed.
trap 'delete_staging_ref' EXIT

echo "[pre-push] Staging HEAD at origin/$staging_branch for remote gate..."
# --force so repeated pushes of the same branch name (rare but possible on
# force-push of main) overwrite the stale staging ref. The stale ref is still
# cleaned up by the EXIT trap.
if ! git push --no-verify --force origin "$local_head_sha:refs/heads/$staging_branch"; then
  echo "[pre-push] BLOCKED: failed to stage HEAD at origin/$staging_branch — aborting before tests."
  exit 1
fi

gate_failed() {
  local label="$1"
  echo "[pre-push] BLOCKED: $label"
  echo "[pre-push] origin/main is unchanged; your local commits are untouched."
  exit 1
}

echo "[pre-push] Running dashboard + server tests in parallel on remote (branch: $staging_branch)..."
# Both phases run inside ONE torque-remote SSH session so the (~80s)
# git fetch+checkout+reset sync only happens once instead of twice. Inside
# that session, dashboard and server tests run as background jobs in
# parallel — dashboard finishes in ~100s, server in ~200s, so wall time
# is bounded by the server run. Each phase is wrapped in `timeout` so a
# hung vitest process can't stall the gate forever.
#
# The perf gate runs SEQUENTIALLY after tests pass (see below). Earlier we
# tried bundling perf into this parallel block to save the second SSH sync,
# but cold-import.tools / cold-import.task-manager / worktree-lifecycle
# measurements got contaminated by concurrent vitest CPU/IO load — the
# perf gate fired false-positive regressions on otherwise clean pushes.
# Sequential perf trades ~80s of wall time for measurement reliability.
# See project_test_gate_perf_session.md for the diagnosis.
#
# Output is line-prefixed [dash]/[serv] so the interleaved stream stays
# legible; tee in run_with_flake_retry streams it live to the user so the
# gate doesn't look frozen during long phases.
#
# IMPORTANT: each phase cd's into its own subdirectory before invoking
# vitest so the tuned per-package config is picked up
# (server/vitest.config.js: pool=threads, retry=1 — the root config has
# pool=forks with no retry which reproducibly produces cross-file flakes;
# dashboard/vitest.config.js: jsdom + react plugin).
#
# Exit code: $((dash_exit + serv_exit)) — non-zero if either failed.
cd "$REPO_ROOT"
remote_parallel_cmd=$(cat <<EOF
set -uo pipefail
DASH_EXIT_FILE=\$(mktemp)
SERV_EXIT_FILE=\$(mktemp)
{
  timeout ${PHASE_TIMEOUT_SECS} bash -lc "cd dashboard && npx vitest run --reporter=dot"
  echo \$? > "\$DASH_EXIT_FILE"
} 2>&1 | sed -u "s/^/[dash] /" &
DASH_PID=\$!
{
  timeout ${PHASE_TIMEOUT_SECS} bash -lc "cd server && npx vitest run --reporter=dot"
  echo \$? > "\$SERV_EXIT_FILE"
} 2>&1 | sed -u "s/^/[serv] /" &
SERV_PID=\$!
wait \$DASH_PID 2>/dev/null
wait \$SERV_PID 2>/dev/null
DASH_EXIT=\$(cat "\$DASH_EXIT_FILE" 2>/dev/null || echo "1")
SERV_EXIT=\$(cat "\$SERV_EXIT_FILE" 2>/dev/null || echo "1")
rm -f "\$DASH_EXIT_FILE" "\$SERV_EXIT_FILE"
echo "[gate-end] dash_exit=\$DASH_EXIT serv_exit=\$SERV_EXIT"
exit \$((DASH_EXIT + SERV_EXIT))
EOF
)
run_with_flake_retry "Test gate" "$TORQUE_REMOTE_CMD --suite gate --branch $staging_branch bash -c $(printf %q "$remote_parallel_cmd")"
combined_output="$RETRIED_OUTPUT"
combined_exit="$RETRIED_EXIT"

# Split combined output into per-phase streams for failure analysis.
dash_output=$(echo "$combined_output" | grep '^\[dash\] ' | sed 's/^\[dash\] //')
server_output=$(echo "$combined_output" | grep '^\[serv\] ' | sed 's/^\[serv\] //')

# The gate-end marker reports per-phase exits even when overall exit code
# is nonzero from `set -uo pipefail` weirdness. Prefer the marker when
# present.
if echo "$combined_output" | grep -qE '\[gate-end\] dash_exit=[0-9]'; then
  dash_exit=$(echo "$combined_output" | grep '\[gate-end\]' | sed -E 's/.*dash_exit=([0-9]+).*/\1/' | tail -1)
  server_exit=$(echo "$combined_output" | grep '\[gate-end\]' | sed -E 's/.*serv_exit=([0-9]+).*/\1/' | tail -1)
else
  dash_exit="$combined_exit"
  server_exit="$combined_exit"
fi

if [ "$dash_exit" -ne 0 ] || tests_have_failures "$dash_output"; then
  echo "$dash_output" | tail -10
  gate_failed "Dashboard tests failed (exit $dash_exit)"
fi
if [ "$server_exit" -ne 0 ] || tests_have_failures "$server_output"; then
  echo "$server_output" | tail -10
  gate_failed "Server tests failed (exit $server_exit)"
fi

# ---------------------------------------------------------------------------
# Perf regression gate: runs SEQUENTIALLY after tests pass, against the
# same staging-branch ref. Sequential is intentional — running perf in
# parallel with the test phase contaminated cold-import.* and
# worktree-lifecycle measurements with vitest CPU/IO contention, firing
# false-positive regressions. The ~80s second sync is the cost of
# reliable perf measurements.
# ---------------------------------------------------------------------------
echo "[pre-push] Running perf regression gate against $staging_branch..."

set +e
PERF_OUT=$("$TORQUE_REMOTE_BIN" --suite gate --branch "$staging_branch" bash -c "cd server && node perf/run-perf.js" 2>&1)
PERF_STATUS=$?
set -e

echo "$PERF_OUT"

if [ "$PERF_STATUS" -ne 0 ]; then
  if [ "${PERF_GATE_BYPASS:-0}" = "1" ]; then
    echo "[pre-push] PERF_GATE_BYPASS=1 set — perf regressions logged but push allowed"
    AUDIT_LINE="[$(date -Iseconds 2>/dev/null || date)] BYPASS sha=$(git rev-parse HEAD) reason=PERF_GATE_BYPASS user=$(git config user.email 2>/dev/null || echo unknown)"
    mkdir -p "$REPO_ROOT/server/perf"
    echo "$AUDIT_LINE" >> "$REPO_ROOT/server/perf/bypass-audit.log"
  else
    echo "[pre-push] BLOCKED: perf regression gate failed (exit $PERF_STATUS)"
    echo "[pre-push] To bypass for incident response: PERF_GATE_BYPASS=1 git push"
    exit 1
  fi
fi

# perf-baseline trailer enforcement: any commit in the push that touches
# server/perf/baseline.json must carry a perf-baseline: trailer.
if git rev-parse --verify origin/main >/dev/null 2>&1; then
  remote_main_sha=$(git rev-parse origin/main)
  for sha in $(git rev-list "$remote_main_sha..$local_head_sha" 2>/dev/null); do
    if git show --name-only --format= "$sha" | grep -q '^server/perf/baseline\.json$'; then
      if ! node "$REPO_ROOT/scripts/perf-baseline-trailer.js" "$sha"; then
        echo "[pre-push] BLOCKED: commit $sha modifies server/perf/baseline.json without a valid perf-baseline: trailer"
        exit 1
      fi
    fi
  done
fi

echo "Running DB query audit..."
node "$REPO_ROOT/scripts/audit-db-queries.js"
if [ $? -ne 0 ]; then
  echo "ERROR: DB query audit failed. Add @full-scan: annotations or add missing indexes."
  exit 1
fi

echo "[pre-push] All tests passed — git will now push refs/heads/main."
