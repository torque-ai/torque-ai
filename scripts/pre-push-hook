#!/usr/bin/env bash
# Two-tier pre-push flow:
# - Pushes targeting refs/heads/main run the full dashboard + remote server gate.
# - The existing gate still pushes HEAD to origin/main, runs remote tests, and rolls back on failure.
# - Pushes that only update non-main refs skip tests so feature-branch iteration stays fast.
# - Delete-only pushes are always allowed and skipped from gating analysis.
# - When a branch is later merged or pushed to main, the full gate runs again there.
# - Use git push --no-verify as the escape hatch when bypassing the hook is intentional.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

ZERO_SHA="0000000000000000000000000000000000000000"
remote_refs=()

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  already_seen=0
  for existing_ref in "${remote_refs[@]}"; do
    if [ "$existing_ref" = "$remote_ref" ]; then
      already_seen=1
      break
    fi
  done

  if [ "$already_seen" -eq 0 ]; then
    remote_refs+=("$remote_ref")
  fi
done

if [ "${#remote_refs[@]}" -eq 0 ]; then
  echo "[pre-push] Delete-only push, allowing."
  exit 0
fi

main_push=0
for remote_ref in "${remote_refs[@]}"; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    main_push=1
    break
  fi
done

if [ "$main_push" -eq 0 ]; then
  echo "[pre-push] Skipping tests for feature-branch push (${remote_refs[*]}). Main merges will be gated."
  exit 0
fi

# vitest prints two summary lines:
#   Test Files  1 failed | 890 passed | 4 skipped (895)
#   Tests       18564 passed | 27 skipped | 10 todo (18601)
# A file-load failure (import error, syntax) increments "Test Files failed"
# without any individual test recording as failed — so the check must match
# either line. The previous 'Tests .* failed' pattern missed this case and
# silently let pushes through with a red test file.
tests_have_failures() {
  local output="$1"
  echo "$output" | grep -qE '^[[:space:]]*(Test Files|Tests)[[:space:]].*failed'
}

echo "[pre-push] Running dashboard tests on remote..."
# Dashboard tests used to run locally, but local CPU contention with the
# live TORQUE server (factory loops, stall watchers, event bus) caused
# waitFor-timeout flakes (seen on ErrorBoundary.test under factory load).
# Remote has consistent headroom and already runs the server suite — match
# that path so both test runs share an env.
cd "$REPO_ROOT/dashboard"
set +e
dash_output=$(torque-remote npx vitest run --config vitest.config.js --reporter=dot 2>&1)
dash_exit=$?
set -e
echo "$dash_output" | tail -5
if [ "$dash_exit" -ne 0 ] || tests_have_failures "$dash_output"; then
  echo "[pre-push] BLOCKED: Dashboard tests failed (exit $dash_exit)"
  exit 1
fi

echo "[pre-push] Running server tests on remote..."
# Refresh origin/main locally so the rollback target matches the current remote
# ref and is guaranteed to exist in the local object database.
git fetch origin refs/heads/main:refs/remotes/origin/main >/dev/null
previous_sha="$(git rev-parse refs/remotes/origin/main)"

echo "[pre-push] Pushing HEAD to origin/main for remote server tests..."
git push --no-verify origin HEAD:refs/heads/main

cd "$REPO_ROOT"
set +e
server_output=$(torque-remote npx vitest run --reporter=dot 2>&1)
server_exit=$?
echo "$server_output" | tail -5
set -e
if [ "$server_exit" -ne 0 ] || tests_have_failures "$server_output"; then
  echo "[pre-push] Server tests failed; rolling origin/main back to $previous_sha..."
  if ! git push --no-verify --force origin "$previous_sha":refs/heads/main; then
    echo "[pre-push] BLOCKED: Server tests failed and rollback push failed"
    exit 1
  fi
  echo "[pre-push] BLOCKED: Server tests failed"
  exit 1
fi

echo "[pre-push] All tests passed — push allowed"
