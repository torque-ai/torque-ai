      {"provider": "groq", "model": "openai/gpt-oss-120b"},
      {"provider": "cerebras", "model": "qwen-3-235b-a22b-instruct-2507"},
      {"provider": "google-ai", "model": "gemini-2.5-flash"}
    ],
    "default": [
