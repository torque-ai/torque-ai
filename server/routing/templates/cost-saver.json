{
  "name": "Cost Saver",
  "description": "Local Ollama first, free cloud fallback only for complex tasks",
  "rules": {
    "security": "ollama",
    "xaml_wpf": "ollama",
    "architectural": "ollama",
    "reasoning": "ollama",
    "large_code_gen": "ollama",
    "documentation": "ollama",
    "simple_generation": "ollama",
    "targeted_file_edit": "hashline-ollama",
    "default": "ollama"
  },
  "complexity_overrides": {
    "large_code_gen": { "complex": "ollama-cloud" },
    "reasoning": { "complex": "cerebras" },
    "architectural": { "complex": "ollama-cloud" }
  }
}
