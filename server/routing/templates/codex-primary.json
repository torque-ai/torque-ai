{
  "name": "Codex Primary",
  "description": "Codex for action work, text-gen providers for plan generation",
  "rules": {
    "security": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ],
    "xaml_wpf": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ],
    "architectural": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ],
    "reasoning": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ],
    "large_code_gen": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ],
    "documentation": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ],
    "simple_generation": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ],
    "plan_generation": [
      {"provider": "cerebras", "model": "qwen-3-235b-a22b-instruct-2507"},
      {"provider": "groq", "model": "openai/gpt-oss-120b"},
      {"provider": "ollama"}
    ],
    "targeted_file_edit": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ],
    "default": [
      {"provider": "codex"},
      {"provider": "claude-cli"},
      {"provider": "ollama"}
    ]
  },
  "complexity_overrides": {}
