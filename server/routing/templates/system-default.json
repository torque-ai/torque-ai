{
  "name": "System Default",
  "description": "Balanced free routing — cerebras for speed, ollama-cloud for heavy tasks, local for simple",
  "rules": {
    "security": "cerebras",
    "xaml_wpf": "cerebras",
    "architectural": "ollama-cloud",
    "reasoning": "ollama-cloud",
    "large_code_gen": "ollama-cloud",
    "documentation": "groq",
    "simple_generation": "cerebras",
    "targeted_file_edit": "cerebras",
    "default": "cerebras"
  },
  "complexity_overrides": {
    "targeted_file_edit": { "complex": "ollama-cloud" },
    "large_code_gen": { "simple": "cerebras" }
  }
}
