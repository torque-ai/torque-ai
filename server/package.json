{
  "name": "torque-server",
  "version": "2.1.0",
  "description": "TORQUE MCP server — automated software factory for autonomous code generation, verification, and release",
  "license": "MIT",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "test": "vitest run --config vitest.config.js",
    "perf": "node perf/run-perf.js",
    "test:unit": "vitest run --reporter=verbose tests/db-*.test.js tests/handler-*.test.js tests/validation-*.test.js tests/error-*.test.js",
    "test:integration": "vitest run --reporter=verbose tests/e2e-*.test.js tests/close-handler-*.test.js tests/task-operations.test.js",
    "test:integration:rest": "vitest run --reporter=verbose tests/rest-provider-host-routes.integration.test.js tests/rest-v2-inference-tasks.integration.test.js tests/rest-v2-async-lifecycle.integration.test.js tests/rest-v2-concurrency.integration.test.js",
    "ci:live-rest-readiness-local": "node scripts/check-live-rest-readiness.js",
    "ci:live-rest-readiness-local:async": "node scripts/check-live-rest-readiness.js --with-async-defaults",
    "ci:live-rest-readiness-local:async-concurrency": "node scripts/check-live-rest-readiness.js --with-async-defaults --with-concurrency-defaults",
    "ci:live-rest-readiness-local:async-concurrency:codex-claude": "node scripts/check-live-rest-readiness.js --with-async-defaults --with-concurrency-defaults-codex-claude",
    "ci:mcp-launch-readiness": "node scripts/mcp-launch-readiness.js",
    "ci:dashboard-mutation-smoke": "node scripts/smoke-dashboard-mutations.js",
    "ci:mcp-readiness-pack": "node scripts/mcp-readiness-pack.js",
    "ci:mcp-dual-agent-smoke": "node scripts/mcp-dual-agent-smoke.js",
    "ci:live-rest-local": "node scripts/run-live-rest-local.js",
    "ci:live-rest-local:async": "node scripts/run-live-rest-local.js --with-async-defaults",
    "ci:live-rest-local:async-concurrency": "node scripts/run-live-rest-local.js --with-async-defaults --with-concurrency-defaults",
    "ci:live-rest-local:async-concurrency:codex-claude": "node scripts/run-live-rest-local.js --with-async-defaults --with-concurrency-defaults-codex-claude",
    "test:stress": "vitest run --reporter=verbose tests/chaos-*.test.js",
    "test:smoke": "vitest run --reporter=verbose tests/task-operations.test.js tests/api-server.test.js tests/safe-env.test.js",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:di": "node scripts/check-no-direct-db-import.js"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@leichtgewicht/ip-codec": "^2.0.5",
    "ajv": "^6.14.0",
    "better-sqlite3": "^12.8.0",
    "bonjour-service": "^1.3.0",
    "js-yaml": "^4.1.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-typescript": "^0.23.2",
    "undici": "^7.24.4",
    "uuid": "^14.0.0",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "bcryptjs": "^3.0.3",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "jsdom": "^29.0.1",
    "vitest": "^4.0.18"
  }
}
