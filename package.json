{
  "name": "torque-ai",
  "version": "1.0.0-beta.1",
  "description": "A dark software factory for Claude Code. Discover, plan, execute, verify, remediate, and release — autonomously across local and cloud LLM providers.",
  "main": "server/index.js",
  "bin": {
    "torque": "bin/torque.js",
    "torque-remote": "bin/torque-remote"
  },
  "scripts": {
    "start": "node server/index.js",
    "test": "cd server && npx vitest run",
    "test:smoke": "cd server && npm run test:smoke",
    "lint": "cd server && npx eslint .",
    "build:dashboard": "cd dashboard && npm run build",
    "prepublishOnly": "npm run build:dashboard"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp", "ai", "orchestration", "llm", "coding", "ollama",
    "claude", "codex", "workflow", "dark-factory", "multi-provider",
    "smart-routing", "quality-gates", "auto-remediation", "autonomous"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/torque-ai/torque-ai.git"
  },
  "homepage": "https://torque-ai.dev",
  "bugs": {
    "url": "https://github.com/torque-ai/torque-ai/issues"
  },
  "author": "<git-user>",
  "files": [
    "server/**/*.js",
    "server/package.json",
    "server/package-lock.json",
    "server/docs/api/",
    "server/docs/guides/",
    "server/docs/runbooks/",
    "!server/tests/",
    "!server/node_modules/",
    "!server/coverage/",
    "!server/artifacts/",
    "!server/eslint.config.js",
    "!server/vitest.config.js",
    "!server/eng.traineddata",
    "!server/**/*.test.js",
    "cli/",
    "bin/",
    "dashboard/dist/",
    ".claude/commands/",
    ".claude-plugin/",
    "CLAUDE.md",
    "LICENSE",
    "README.md",
    ".env.example"
  ],
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.0"
  }
}